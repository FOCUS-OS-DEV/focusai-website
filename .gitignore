# Vercel
.vercel

# Dependencies
node_modules/

# Environment variables
.env
.env.*

# Local settings (machine-specific)
*.local
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db
nul

# Development artifacts
*.psi.json
pagespeed-result.json
ai-news-digest.json

# Session transcripts (auto-generated, grow unbounded)
memory/sessions/

# Generated images (output of generate-*.mjs scripts)
focusai-website/generated-images/

# Binary files in dist/ — NEVER commit (break cPanel deploy via CRLF/LF mismatch)
# These should be served via Cloudinary CDN, not from dist/
focusai-website/dist/**/*.pdf
focusai-website/dist/**/*.zip
focusai-website/dist/**/*.mp4
focusai-website/dist/**/*.webm

# Large local-only files
*.pdf
!focusai-website/public/.htaccess

# Scripts with API keys (Google AI, N8N) — NEVER commit
_fix_webhooks.mjs
_create_workflows.mjs
focusai-website/generate-*.mjs
