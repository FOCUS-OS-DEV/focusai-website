---
/**
 * CTA Contact Section - Cyberpunk Terminal Interface
 */
import { siteConfig, getMailtoLink, getPhoneLink } from '../data';

interface Props { source?: string; }
const { source = 'homepage-contact' } = Astro.props;

const webhookUrl = "https://focusai.app.n8n.cloud/webhook/contact-form";
const contactMethods = [
  {
    code: "EMAIL",
    label: "אימייל",
    value: siteConfig.contact.email,
    href: getMailtoLink(),
    neonColor: "#e879f9"
  },
  {
    code: "WHATSAPP",
    label: "WhatsApp",
    value: siteConfig.contact.phone,
    href: siteConfig.contact.whatsapp,
    neonColor: "#a855f7"
  },
  {
    code: "PHONE",
    label: "טלפון",
    value: siteConfig.contact.phone,
    href: getPhoneLink(),
    neonColor: "#c084fc"
  }
];

const quickStats = [
  { code: "SPEED", text: "תגובה תוך 24 שעות" },
  { code: "FREE", text: "שיחה ללא התחייבות" },
  { code: "SECURE", text: "פרטיות מובטחת" },
];

---

<section id="contact" class="py-12 md:py-16 relative overflow-hidden bg-[#0a0a0f]" data-section>
  <!-- Background effects -->
  <div class="absolute inset-0">
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-[#a855f7]/5 rounded-full blur-[200px]"></div>
    <div class="absolute bottom-0 left-1/4 w-80 h-80 bg-[#c084fc]/5 rounded-full blur-[200px]"></div>
    <!-- Fingerprint background - right side -->
    <img
      src="https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_700/v1765571815/FOCUS_LOGO-06_2_grkja9.png"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      width="700"
      height="700"
      class="absolute top-1/2 right-0 w-[500px] lg:w-[700px] h-auto -translate-y-1/2 opacity-[0.15] pointer-events-none select-none"
    />
  </div>


  <div class="container relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <!-- Terminal badge -->
      <div class="inline-flex items-center gap-3 px-4 py-2 bg-[#12121a] border border-[#a855f7]/30 mb-8" data-animate="fade-up">
        <span class="w-2 h-2 rounded-full bg-[#a855f7] animate-pulse"></span>
        <span class="font-mono text-sm font-semibold text-[#a855f7] uppercase tracking-[0.15em]">CONTACT_TERMINAL</span>
      </div>

      <h2 class="text-2xl sm:text-3xl md:text-5xl lg:text-7xl font-black mb-6" data-animate="glitch" data-delay="0.1">
        <span class="text-[#f5f5fa]">בואו</span>
        <span class="gradient-text-glow"> נדבר</span>
      </h2>

      <p class="text-xl text-[#b0b0c0] max-w-2xl mx-auto font-mono" data-animate="fade-up" data-delay="0.2">
        <span class="text-[#a855f7]">&gt;</span> השאירו פרטים ונחזור אליכם
        <span class="text-[#f5f5fa]"> תוך 24 שעות.</span>
      </p>
    </div>


    <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 max-w-6xl mx-auto">
      <!-- Form - Takes 3 columns -->
      <div class="lg:col-span-3">
        <div
          class="relative bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] overflow-hidden rounded-2xl shadow-[0_8px_32px_rgba(0,0,0,0.3)]"
          data-animate="terminal"
        >
          {/* Glass header */}
          <div class="flex items-center justify-between px-6 py-3 border-b border-white/[0.06] bg-white/[0.03] backdrop-blur-sm rounded-t-2xl">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
            </div>
            <span class="font-mono text-xs font-medium text-[#b0b0c0]/60 tracking-wider uppercase">השאירו פרטים</span>
          </div>

          <form id="contact-form" class="p-8 lg:p-10 space-y-6" data-source={source}>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="form-group">
                <label for="cta-firstName" class="block font-mono text-sm font-medium text-[#a855f7] uppercase tracking-wider mb-2">
                  <span class="text-[#b0b0c0]">[REQ]</span> שם פרטי
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#a855f7] font-mono">&gt;</span>
                  <input
                    type="text"
                    id="cta-firstName"
                    name="firstName"
                    required
                    pattern={"[\\u0590-\\u05FFa-zA-Z\\s'\\-]{2,50}"}
                    title="שם פרטי - אותיות בלבד, 2-50 תווים"
                    class="w-full pl-10 pr-4 py-3.5 bg-[#0a0a0f] border border-[#a855f7]/15 text-[#f5f5fa] font-mono text-base focus:outline-none focus:border-[#a855f7] focus:ring-2 focus:ring-[#a855f7]/25 focus:shadow-[0_0_20px_rgba(168,85,247,0.2)] transition-all duration-300 rounded-xl"
                    placeholder="שם פרטי_"
                  />
                </div>
              </div>

              <div class="form-group">
                <label for="cta-lastName" class="block font-mono text-sm font-medium text-[#a855f7] uppercase tracking-wider mb-2">
                  <span class="text-[#b0b0c0]">[REQ]</span> שם משפחה
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#a855f7] font-mono">&gt;</span>
                  <input
                    type="text"
                    id="cta-lastName"
                    name="lastName"
                    required
                    pattern={"[\\u0590-\\u05FFa-zA-Z\\s'\\-]{2,50}"}
                    title="שם משפחה - אותיות בלבד, 2-50 תווים"
                    class="w-full pl-10 pr-4 py-3.5 bg-[#0a0a0f] border border-[#a855f7]/15 text-[#f5f5fa] font-mono text-base focus:outline-none focus:border-[#a855f7] focus:ring-2 focus:ring-[#a855f7]/25 focus:shadow-[0_0_20px_rgba(168,85,247,0.2)] transition-all duration-300 rounded-xl"
                    placeholder="שם משפחה_"
                  />
                </div>
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div class="form-group">
                <label for="cta-phone" class="block font-mono text-sm font-medium text-[#a855f7] uppercase tracking-wider mb-2">
                  <span class="text-[#b0b0c0]">[REQ]</span> טלפון
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#a855f7] font-mono">&gt;</span>
                  <input
                    type="tel"
                    id="cta-phone"
                    name="phone"
                    required
                    inputmode="tel"
                    pattern="0[2-9][0-9\-\s]{7,11}"
                    title="מספר טלפון ישראלי תקין, לדוגמה: 052-1234567"
                    class="w-full pl-10 pr-4 py-3.5 bg-[#0a0a0f] border border-[#a855f7]/15 text-[#f5f5fa] font-mono text-base focus:outline-none focus:border-[#a855f7] focus:ring-2 focus:ring-[#a855f7]/25 focus:shadow-[0_0_20px_rgba(168,85,247,0.2)] transition-all duration-300 rounded-xl"
                    placeholder="050-000-0000_"
                  />
                </div>
              </div>

              <div class="form-group">
                <label for="cta-email" class="block font-mono text-sm font-medium text-[#a855f7] uppercase tracking-wider mb-2">
                  <span class="text-[#b0b0c0]">[REQ]</span> אימייל
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#a855f7] font-mono">&gt;</span>
                  <input
                    type="email"
                    id="cta-email"
                    name="email"
                    required
                    class="w-full pl-10 pr-4 py-3.5 bg-[#0a0a0f] border border-[#a855f7]/15 text-[#f5f5fa] font-mono text-base focus:outline-none focus:border-[#a855f7] focus:ring-2 focus:ring-[#a855f7]/25 focus:shadow-[0_0_20px_rgba(168,85,247,0.2)] transition-all duration-300 rounded-xl"
                    placeholder="email@example.com_"
                  />
                </div>
              </div>
            </div>

            <div class="flex items-start gap-2 text-right">
              <input type="checkbox" id="cta-privacy" name="privacy" required class="mt-1 accent-[#a855f7]"/>
              <label for="cta-privacy" class="text-xs text-white/50">
                קראתי ואני מסכים/ה ל<a href="/terms" class="text-[#a855f7] underline">תנאי השימוש</a> ול<a href="/privacy-policy" class="text-[#a855f7] underline">מדיניות הפרטיות</a>. *
              </label>
            </div>
            <div class="flex items-start gap-2 text-right">
              <input type="checkbox" id="cta-marketing" name="marketing" class="mt-1 accent-[#a855f7]"/>
              <label for="cta-marketing" class="text-xs text-white/50">
                אני מסכים/ה לקבל דיוור מ-Focus AI. ניתן לבטל בכל עת.
              </label>
            </div>

            <!-- Honeypot anti-bot field -->
            <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <button
              type="submit"
              class="submit-btn group w-full min-h-[52px] py-4 bg-[#a855f7] text-[#0a0a0f] font-mono font-bold uppercase tracking-wider shadow-[0_0_30px_rgba(168,85,247,0.5)] hover:shadow-[0_0_50px_rgba(168,85,247,0.7)] hover:brightness-110 active:scale-[0.98] transition-all duration-300 flex items-center justify-center gap-3 rounded-full"
            >
              <span class="w-2 h-2 rounded-full bg-[#0a0a0f] animate-pulse"></span>
              <span>SUBMIT_REQUEST</span>
            </button>
          </form>
        </div>
      </div>

      <!-- Contact Info - Takes 2 columns -->
      <div class="lg:col-span-2">
        <div
          class="bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] overflow-hidden rounded-2xl shadow-[0_8px_32px_rgba(0,0,0,0.3)] h-full flex flex-col"
          data-animate="slide-left" data-delay="0.2"
        >
          {/* Glass header */}
          <div class="flex items-center justify-between px-6 py-3 border-b border-white/[0.06] bg-white/[0.03] backdrop-blur-sm rounded-t-2xl">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
            </div>
            <span class="font-mono text-xs font-medium text-[#b0b0c0]/60 tracking-wider uppercase">דרכי התקשרות</span>
          </div>

          <div class="p-6 space-y-4 flex-1 flex flex-col justify-center">
            {contactMethods.map((method) => (
              <a
                href={method.href}
                class="group flex items-center gap-4 p-4 bg-[#0a0a0f] border border-[#a855f7]/15 hover:border-[#a855f7]/50 transition-all duration-300 rounded-xl"
              >
                <div
                  class="w-12 h-12 flex items-center justify-center border transition-all duration-300"
                  style={`border-color: ${method.neonColor}50; color: ${method.neonColor};`}
                >
                  {method.code === "EMAIL" && (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                  )}
                  {method.code === "WHATSAPP" && (
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                  )}
                  {method.code === "PHONE" && (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                    </svg>
                  )}
                </div>
                <div class="flex-1">
                  <div class="text-sm font-medium text-[#b0b0c0] font-mono uppercase tracking-wider mb-0.5">[{method.code}]</div>
                  <div class="font-mono text-[#f5f5fa] group-hover:text-[#a855f7] transition-colors">{method.value}</div>
                </div>
                <span class="w-2 h-2 rounded-full bg-[#b0b0c0] group-hover:bg-[#a855f7] transition-colors"></span>
              </a>
            ))}
          </div>

          {/* Quick stats */}
          <div class="px-6 pb-6 pt-2 space-y-3">
            {quickStats.map((stat) => (
              <div class="flex items-center gap-3 text-sm font-mono">
                <span class="text-[#a855f7]">&gt;</span>
                <span class="text-[#b0b0c0]">{stat.text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { supabaseInsert, CONSENT_TEXTS } from '@/utils/form-helpers';
  import { siteConfig } from '@/data/config';
  const WEBHOOK_URL = siteConfig.webhooks.contactForm;

  const form = document.getElementById('contact-form') as HTMLFormElement;

  // Clear errors on focus
  form?.querySelectorAll('input, select, textarea').forEach(el => {
    el.addEventListener('focus', () => el.classList.remove('error'));
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot check — silently drop bot submissions
    const honeypot = form.querySelector('[name="website"]') as HTMLInputElement;
    if (honeypot?.value) return;

    // --- JS Validation ---
    const firstNameEl = form.querySelector('[name="firstName"]') as HTMLInputElement;
    const lastNameEl = form.querySelector('[name="lastName"]') as HTMLInputElement;
    const phoneEl = form.querySelector('[name="phone"]') as HTMLInputElement;
    const emailEl = form.querySelector('[name="email"]') as HTMLInputElement;
    const privacyEl = form.querySelector('[name="privacy"]') as HTMLInputElement;

    form.querySelectorAll('.error').forEach(el => el.classList.remove('error'));

    let valid = true;
    function check(el: HTMLElement | null, ok: boolean) {
      if (!ok && el) { el.classList.add('error'); if (valid) el.focus(); valid = false; }
    }

    const nameRe = /^[\u0590-\u05FFa-zA-Z\s'\-]{2,50}$/;
    check(firstNameEl, !!firstNameEl?.value.trim() && nameRe.test(firstNameEl.value.trim()));
    check(lastNameEl, !!lastNameEl?.value.trim() && nameRe.test(lastNameEl.value.trim()));
    const phoneClean = (phoneEl?.value || '').replace(/[-\s]/g, '');
    check(phoneEl, /^0[2-9]\d{7,8}$/.test(phoneClean));
    check(emailEl, !!emailEl?.value.trim() && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim()));
    check(privacyEl, !!privacyEl?.checked);

    if (!valid) return;

    // --- Collect data ---
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const btnText = submitBtn?.querySelector('span:last-child');
    const originalText = btnText?.textContent || '';

    if (submitBtn) submitBtn.disabled = true;
    if (btnText) btnText.textContent = 'שולח...';

    const firstName = (firstNameEl?.value || '').trim();
    const lastName = (lastNameEl?.value || '').trim();
    const phone = phoneClean;
    const email = (emailEl?.value || '').trim();
    const source = form.dataset.source || 'homepage-contact';
    const consentMarketing = !!marketingEl?.checked;

    // Get tracking data from Tracker.astro
    const tracking = typeof window.__fai_getTracking === 'function'
      ? window.__fai_getTracking()
      : {};

    // Generate event_id for Pixel ↔ CAPI deduplication
    const eventId = typeof crypto !== 'undefined' && crypto.randomUUID
      ? crypto.randomUUID()
      : 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
          const r = Math.random() * 16 | 0;
          return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
        });

    // --- 1. Send to N8N webhook (primary — with tracking data) ---
    const params = new URLSearchParams();
    params.append('firstName', firstName);
    params.append('lastName', lastName);
    params.append('phone', phone);
    params.append('email', email);
    params.append('source', source);
    params.append('marketing_consent', consentMarketing ? 'yes' : 'no');
    params.append('event_id', eventId);
    if (tracking.utm_source) params.append('utm_source', tracking.utm_source);
    if (tracking.utm_medium) params.append('utm_medium', tracking.utm_medium);
    if (tracking.utm_campaign) params.append('utm_campaign', tracking.utm_campaign);
    if (tracking.utm_content) params.append('utm_content', tracking.utm_content);
    if (tracking.utm_term) params.append('utm_term', tracking.utm_term);
    if (tracking.fbclid) params.append('fbclid', tracking.fbclid);
    if (tracking.gclid) params.append('gclid', tracking.gclid);
    if (tracking.fbc) params.append('fbc', tracking.fbc);
    if (tracking.fbp) params.append('fbp', tracking.fbp);

    // --- 2. Log consent to Supabase (append-only audit trail) ---
    supabaseInsert('consent_log', {
      email: email,
      phone: phone,
      consent_privacy: true,
      consent_marketing: consentMarketing,
      consent_text_version: CONSENT_TEXTS.version,
      consent_privacy_text: CONSENT_TEXTS.privacy,
      consent_marketing_text: CONSENT_TEXTS.marketing,
      form_source: source,
      page_url: window.location.href,
      user_agent: navigator.userAgent
    });

    // --- 3. Log submission to Supabase (lead + full tracking) ---
    supabaseInsert('form_submissions', {
      first_name: firstName,
      last_name: lastName,
      email: email,
      phone: phone,
      form_source: source,
      page_url: window.location.href,
      utm_source: tracking.utm_source || null,
      utm_medium: tracking.utm_medium || null,
      utm_campaign: tracking.utm_campaign || null,
      utm_content: tracking.utm_content || null,
      utm_term: tracking.utm_term || null,
      fbclid: tracking.fbclid || null,
      fbc: tracking.fbc || null,
      fbp: tracking.fbp || null,
      gclid: tracking.gclid || null,
      event_id: eventId,
      consent_privacy: true,
      consent_marketing: consentMarketing,
      user_agent: navigator.userAgent,
      referrer: tracking.referrer || null,
      device_type: tracking.device_type || null,
      session_id: tracking.session_id || null
    });

    // --- 4. Send to N8N with retry ---
    try {
      let lastError;
      for (let attempt = 0; attempt < 3; attempt++) {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 15000);
        try {
          await fetch(WEBHOOK_URL, { method: 'POST', body: params, signal: controller.signal });
          clearTimeout(timeout);

          // Fire Pixel Lead with eventID for CAPI deduplication
          if (typeof window.fbq === 'function') {
            window.fbq('track', 'Lead', {}, { eventID: eventId });
          }

          window.location.href = '/academy/thank-you';
          return;
        } catch (err) {
          lastError = err;
          if (attempt < 2) await new Promise(r => setTimeout(r, (attempt + 1) * 1000));
        }
      }
      throw lastError;
    } catch {
      if (submitBtn) submitBtn.disabled = false;
      if (btnText) btnText.textContent = originalText;
      const errEl = form.querySelector('.form-error') || document.createElement('div');
      errEl.className = 'form-error';
      errEl.textContent = 'שגיאה בשליחת הטופס. אנא נסו שנית.';
      errEl.style.cssText = 'color:#ef4444;font-size:14px;text-align:center;margin-top:12px;padding:8px;background:rgba(239,68,68,0.1);border-radius:8px';
      if (!form.querySelector('.form-error')) form.appendChild(errEl);
    }
  });
</script>

<style>
  .gradient-text-glow {
    background: linear-gradient(90deg, #a855f7, #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px rgba(168, 85, 247, 0.5));
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.04), inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .form-group input.error,
