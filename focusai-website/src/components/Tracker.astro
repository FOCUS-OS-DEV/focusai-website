---
/**
 * Anonymous Analytics Tracker
 * Cookie-free, GDPR-compliant — no consent required
 * Sends pageview and click events to Supabase
 */
---

<script is:inline>
(function() {
  // Skip tracking for excluded browsers (set via console: localStorage.setItem('fai_notrack','1'))
  if (typeof localStorage !== 'undefined' && localStorage.getItem('fai_notrack') === '1') return;

  // Session ID (tab-scoped, resets when tab closes)
  var sid;
  try { sid = sessionStorage.getItem('fai_sid'); if (!sid) { sid = crypto.randomUUID(); sessionStorage.setItem('fai_sid', sid); } } catch(e) { sid = null; }

  // Timezone for geo approximation
  var tz;
  try { tz = Intl.DateTimeFormat().resolvedOptions().timeZone; } catch(e) { tz = null; }

  var SUPABASE_URL = 'https://ueewnvfydrlhyxmbgsus.supabase.co';
  var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVlZXdudmZ5ZHJsaHl4bWJnc3VzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA4NDI4ODcsImV4cCI6MjA4NjQxODg4N30.4EjvZekhleRdufJPxBEgXRkUbhGbG5cjjjBFUa20mjQ';

  function getDeviceType() {
    var w = window.innerWidth;
    if (w < 768) return 'mobile';
    if (w < 1024) return 'tablet';
    return 'desktop';
  }

  // --- Ad tracking: persist UTMs + click IDs in sessionStorage ---
  var TRACKING_KEY = 'fai_tracking';

  function getURLParams() {
    var params = new URLSearchParams(window.location.search);
    return {
      utm_source: params.get('utm_source') || null,
      utm_medium: params.get('utm_medium') || null,
      utm_campaign: params.get('utm_campaign') || null,
      utm_content: params.get('utm_content') || null,
      utm_term: params.get('utm_term') || null,
      fbclid: params.get('fbclid') || null,
      gclid: params.get('gclid') || null
    };
  }

  function buildFbc(fbclid) {
    // Meta fbc format: fb.1.{timestamp_ms}.{fbclid}
    return 'fb.1.' + Date.now() + '.' + fbclid;
  }

  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? decodeURIComponent(match[2]) : null;
  }

  function persistTracking() {
    try {
      var urlParams = getURLParams();
      var hasNewParams = Object.keys(urlParams).some(function(k) { return urlParams[k] !== null; });

      // Load existing tracking data
      var stored = {};
      try { stored = JSON.parse(sessionStorage.getItem(TRACKING_KEY)) || {}; } catch(e) {}

      // If URL has new ad params, overwrite (last-touch attribution)
      if (hasNewParams) {
        Object.keys(urlParams).forEach(function(k) {
          if (urlParams[k] !== null) stored[k] = urlParams[k];
        });

        // Build fbc from fbclid if we got a new one
        if (urlParams.fbclid) {
          stored.fbc = buildFbc(urlParams.fbclid);
        }
      }

      // Read _fbp cookie (set by Meta Pixel) — update each page load
      var fbp = getCookie('_fbp');
      if (fbp) stored.fbp = fbp;

      // Read _fbc cookie (set by Meta Pixel from fbclid) — fallback
      var fbc = getCookie('_fbc');
      if (fbc && !stored.fbc) stored.fbc = fbc;

      sessionStorage.setItem(TRACKING_KEY, JSON.stringify(stored));
      return stored;
    } catch(e) { return {}; }
  }

  // Run on every page load — persist params before they're lost on navigation
  var trackingData = persistTracking();

  function getUTM() {
    return {
      utm_source: trackingData.utm_source || null,
      utm_medium: trackingData.utm_medium || null,
      utm_campaign: trackingData.utm_campaign || null,
      utm_content: trackingData.utm_content || null,
      utm_term: trackingData.utm_term || null
    };
  }

  function getClickType(href) {
    if (!href) return null;
    if (href.startsWith('mailto:')) return 'email';
    if (href.startsWith('tel:')) return 'phone';
    if (href.includes('wa.me') || href.includes('whatsapp.com')) return 'whatsapp';
    try {
      var url = new URL(href, window.location.origin);
      if (url.hostname === window.location.hostname) return 'internal';
      return 'external';
    } catch(e) { return 'external'; }
  }

  function sendEvent(data) {
    var payload = Object.assign({
      page_url: window.location.href,
      page_path: window.location.pathname,
      referrer: document.referrer || null,
      device_type: getDeviceType(),
      screen_width: window.innerWidth,
      session_id: sid,
      timezone: tz
    }, getUTM(), data);

    // Remove null values
    Object.keys(payload).forEach(function(k) {
      if (payload[k] === null || payload[k] === undefined) delete payload[k];
    });

    var url = SUPABASE_URL + '/rest/v1/events';
    try {
      fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
          'Prefer': 'return=minimal'
        },
        body: JSON.stringify(payload),
        keepalive: true
      }).catch(function() {});
    } catch(e) {}
  }

  // Track pageview
  if (!window.__fai_tracked) {
    window.__fai_tracked = true;
    sendEvent({ event_type: 'pageview' });
  }

  // Track clicks on links
  document.addEventListener('click', function(e) {
    var link = e.target.closest('a');
    if (!link) return;
    var href = link.getAttribute('href');
    if (!href || href === '#') return;

    sendEvent({
      event_type: 'click',
      click_url: href,
      click_text: (link.textContent || '').trim().substring(0, 200),
      click_type: getClickType(href)
    });
  });

  // Track form submissions
  document.addEventListener('submit', function(e) {
    var form = e.target;
    sendEvent({
      event_type: 'form_submit',
      click_url: form.action || window.location.href,
      click_text: (form.querySelector('button[type="submit"]') || {}).textContent || 'submit'
    });
  });

  // Expose tracking data for form handlers (CTAContact, standalone pages, etc.)
  // Usage: var data = window.__fai_getTracking();
  window.__fai_getTracking = function() {
    // Re-read from sessionStorage (may have been updated by Meta Pixel since page load)
    var fresh = {};
    try { fresh = JSON.parse(sessionStorage.getItem(TRACKING_KEY)) || {}; } catch(e) {}

    // Update fbp from cookie (Pixel may have set it after our initial read)
    var fbp = getCookie('_fbp');
    if (fbp) fresh.fbp = fbp;

    return {
      utm_source: fresh.utm_source || null,
      utm_medium: fresh.utm_medium || null,
      utm_campaign: fresh.utm_campaign || null,
      utm_content: fresh.utm_content || null,
      utm_term: fresh.utm_term || null,
      fbclid: fresh.fbclid || null,
      gclid: fresh.gclid || null,
      fbc: fresh.fbc || null,
      fbp: fresh.fbp || null,
      session_id: sid,
      device_type: getDeviceType(),
      referrer: document.referrer || null,
      page_url: window.location.href,
      user_agent: navigator.userAgent
    };
  };
})();
</script>
