---
/**
 * Analytics Dashboard — Internal Use Only
 * Route: /admin/analytics/
 * Password-protected React island
 */
import Analytics from '../../components/Analytics.astro';
import AnalyticsBody from '../../components/AnalyticsBody.astro';
import Tracker from '../../components/Tracker.astro';
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics | Focus AI</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&display=swap" rel="stylesheet">
  <Analytics />
  <Tracker />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0a0a0f; }
  </style>
</head>
<body>
  <AnalyticsBody />
  <div id="dashboard">
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#0a0a0f;color:#fff;font-family:Heebo,sans-serif">
      Loading...
    </div>
  </div>

  <script>
    import { createElement } from 'react';
    import { createRoot } from 'react-dom/client';
    import AnalyticsDashboard from '../../components/AnalyticsDashboard';

    const root = createRoot(document.getElementById('dashboard')!);
    root.render(createElement(AnalyticsDashboard));
  </script>
</body>
</html>
