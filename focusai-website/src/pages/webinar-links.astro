  <script>
    // Target: 04 March 2026, 21:00 Israel Standard Time (UTC+2)
    const TARGET = new Date('2026-03-04T21:00:00+02:00').getTime();

    const hoursEl = document.getElementById('timer-hours');
    const minutesEl = document.getElementById('timer-minutes');
    const secondsEl = document.getElementById('timer-seconds');
    const btn = document.getElementById('payment-btn');
    const timerContainer = document.getElementById('timer-container');
    const btnStatus = document.getElementById('btn-status');

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function tick() {
      const now = Date.now();
      const diff = TARGET - now;

      if (diff <= 0) {
        // Timer expired — activate button
        timerContainer.style.display = 'none';
        btn.classList.remove('pointer-events-none', 'opacity-40', 'cursor-not-allowed');
        btn.classList.add('hover:shadow-[0_0_40px_rgba(168,85,247,0.5)]', 'hover:scale-105', 'active:scale-95');
        btnStatus.textContent = 'הכפתור פעיל — לחצו לשריון מקום';
        btnStatus.classList.remove('text-[#b0b0c0]/40');
        btnStatus.classList.add('text-[#a855f7]');
        return;
      }

      const hours = Math.floor(diff / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);

      hoursEl.textContent = pad(hours);
      minutesEl.textContent = pad(minutes);
      secondsEl.textContent = pad(seconds);

      requestAnimationFrame(() => setTimeout(tick, 250));
    }

    tick();
  </script>
