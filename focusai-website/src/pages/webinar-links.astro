---
/**
 * Webinar Links — 04.03.2026
 * Hidden page for webinar participants (no menu, noindex)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="וובינר לבניית סוכן AI ב-N8N | Focus AI" description="צפו בהקלטת הוובינר — בניית סוכן AI ב-N8N + כל הלינקים למשתתפים">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <div class="min-h-screen bg-[#0a0a0f] text-white" dir="rtl">

    <!-- Logo bar -->
    <div class="pt-8 pb-4 text-center">
