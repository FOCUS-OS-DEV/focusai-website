---
/**
 * Focus On Me - Free Resources Hub
 * All free webinars, guides, and Claude Code skills bundles
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "הדרכות, וובינרים וכלים — בחינם | Focus AI";
const pageDescription = "כל המשאבים החינמיים של Focus AI במקום אחד: וובינרים, הדרכות מקצועיות וחבילות סקילים ל-Claude Code למפתחים, מנהלים ואנשי שיווק.";

const webinars = [
  {
    title: 'וובינר Live: סוכן AI ב-N8N',
    description: 'בניית סוכן AI ראשון ב-N8N — צעד אחר צעד, בשידור חי',
    href: '/webinar-n8n-agent',
    cta: 'להרשמה לוובינר',
    isLive: true,
    icon: 'video',
  },
  {
    title: 'הדרכה: סוכני AI',
    description: 'בניית סוכן AI מאפס — מה זה, למה זה חשוב ואיך מתחילים',
    href: '/%D7%95%D7%95%D7%91%D7%99%D7%A0%D7%A8-%D7%91%D7%9E%D7%AA%D7%A0%D7%94-%D7%A1%D7%95%D7%9B%D7%A0%D7%99-%D7%91%D7%99%D7%A0%D7%94-%D7%9E%D7%9C%D7%90%D7%9B%D7%95%D7%AA%D7%99%D7%AA/',
    cta: 'לצפייה בהדרכה',
    icon: 'bot',
  },
  {
    title: 'הדרכה: אוטומציית תוכן',
    description: 'יצירת תוכן עם AI — מאפס ועד פוסט מוכן לפרסום',
    href: '/content-automation-course',
    cta: 'לצפייה בהדרכה',
    icon: 'zap',
  },
];

const skills = [
  {
    title: '50 סקילים למפתחים',
    description: 'סקילים ל-Claude Code מותאמים למפתחים — debug, refactor, testing ועוד',
    href: '/claude-skills-he',
    cta: 'להורדה חינם',
    icon: 'terminal',
  },
  {
    title: '50 סקילים למנהלים ויזמים',
    description: 'סקילים לניהול פרויקטים, כתיבת מסמכים, תכנון אסטרטגי ועוד',
    href: '/claude-skills-managers',
    cta: 'להורדה חינם',
    icon: 'briefcase',
  },
  {
    title: '50 סקילים לשיווק ותוכן',
    description: 'סקילים לכתיבת תוכן, קמפיינים, SEO, סושיאל ועוד',
    href: '/claude-skills-marketing',
    cta: 'להורדה חינם',
    icon: 'megaphone',
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header slot="header" currentPath="/focus-on-me" />

  <!-- ============================================ -->
  <!-- HERO                                          -->
  <!-- ============================================ -->
  <section class="relative min-h-[55vh] flex items-center pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-1/4 right-1/4 w-[600px] h-[600px] bg-[#c084fc]/10 rounded-full blur-[150px]"></div>
      <div class="absolute bottom-1/4 left-1/4 w-[500px] h-[500px] bg-[#a855f7]/10 rounded-full blur-[120px]"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(168, 85, 247, 0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(168, 85, 247, 0.5) 1px, transparent 1px); background-size: 50px 50px;"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10 max-w-5xl text-center">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/[0.03] backdrop-blur-sm border border-white/[0.08] mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
        <span class="text-xs text-[#a855f7] uppercase tracking-[0.2em]">ללא עלות</span>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black mb-6">
        <span class="text-[#f5f5fa]">הדרכות, וובינרים וכלים</span>
        <span class="block mt-2 text-[#a855f7]" style="text-shadow: 0 0 30px rgba(168, 85, 247, 0.4);">בחינם</span>
      </h1>

      <p class="text-lg md:text-xl text-[#b0b0c0] max-w-3xl mx-auto leading-relaxed mb-12">
        כל המשאבים החינמיים של Focus AI במקום אחד —
        <span class="text-[#f5f5fa] font-medium">וובינרים, הדרכות מקצועיות וחבילות סקילים</span>
      </p>

      <!-- Stats -->
      <div class="flex justify-center gap-12 flex-wrap">
        <div class="text-center">
          <div class="text-4xl font-black text-[#a855f7]">6</div>
          <div class="text-sm text-[#b0b0c0] font-mono uppercase tracking-wider">משאבים חינם</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-black text-[#a855f7]">150+</div>
          <div class="text-sm text-[#b0b0c0] font-mono uppercase tracking-wider">סקילים</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-black text-[#a855f7]">3</div>
          <div class="text-sm text-[#b0b0c0] font-mono uppercase tracking-wider">הדרכות מקצועיות</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION A: WEBINARS & GUIDES                  -->
  <!-- ============================================ -->
  <section class="py-16 lg:py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <!-- Section Header -->
      <div class="flex items-center gap-3 mb-12">
        <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
        <span class="font-mono text-xs text-[#b0b0c0]/60 uppercase tracking-wider">WEBINARS & GUIDES</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {webinars.map((item) => (
          <a href={item.href} class="group relative bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.3)] hover:border-[#a855f7]/30 transition-all duration-300">
            <!-- Glass header -->
            <div class="px-6 py-3 border-b border-white/[0.06] bg-white/[0.03] backdrop-blur-sm flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
                <span class="font-mono text-[10px] text-[#b0b0c0]/60 uppercase tracking-wider">
                  {item.isLive ? 'LIVE WEBINAR' : 'FREE GUIDE'}
                </span>
              </div>
              {item.isLive && (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-red-500/90 text-[10px] font-bold uppercase tracking-wider text-white shadow-[0_0_12px_rgba(239,68,68,0.5)]">
                  <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
                  LIVE
                </span>
              )}
            </div>

            <!-- Content -->
            <div class="p-6 flex flex-col items-center text-center min-h-[240px]">
              <!-- Icon -->
              <div class="w-14 h-14 rounded-xl bg-[#a855f7]/10 border border-[#a855f7]/20 flex items-center justify-center mb-5 group-hover:bg-[#a855f7]/20 transition-colors">
                {item.icon === 'video' && (
                  <svg class="w-7 h-7 text-[#a855f7]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="23 7 16 12 23 17 23 7"></polygon>
                    <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
                  </svg>
                )}
                {item.icon === 'bot' && (
                  <svg class="w-7 h-7 text-[#a855f7]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="10" rx="2"></rect>
                    <circle cx="12" cy="5" r="2"></circle>
                    <path d="M12 7v4"></path>
                    <line x1="8" y1="16" x2="8" y2="16"></line>
                    <line x1="16" y1="16" x2="16" y2="16"></line>
                  </svg>
                )}
                {item.icon === 'zap' && (
                  <svg class="w-7 h-7 text-[#a855f7]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                  </svg>
                )}
              </div>

              <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
              <p class="text-sm text-[#b0b0c0] leading-relaxed mb-6 flex-grow">{item.description}</p>

              <!-- CTA -->
              <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#a855f7]/10 border border-[#a855f7]/30 text-[#a855f7] text-sm font-medium rounded-full group-hover:bg-[#a855f7] group-hover:text-[#0a0a0f] transition-all duration-300">
                {item.cta}
                <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION B: CLAUDE CODE SKILLS                 -->
  <!-- ============================================ -->
  <section class="py-16 lg:py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <!-- Section Header -->
      <div class="flex items-center gap-3 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
        <span class="font-mono text-xs text-[#b0b0c0]/60 uppercase tracking-wider">CLAUDE CODE SKILLS</span>
      </div>
      <h2 class="text-2xl md:text-3xl font-black text-[#f5f5fa] mb-12">
        חבילות סקילים ל-<span class="text-[#a855f7]">Claude Code</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {skills.map((item) => (
          <a href={item.href} class="group relative bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.3)] hover:border-[#a855f7]/30 transition-all duration-300">
            <!-- Glass header -->
            <div class="px-6 py-3 border-b border-white/[0.06] bg-white/[0.03] backdrop-blur-sm flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
              <span class="font-mono text-[10px] text-[#b0b0c0]/60 uppercase tracking-wider">FREE DOWNLOAD</span>
            </div>

            <!-- Content -->
            <div class="p-6 flex flex-col items-center text-center min-h-[240px]">
              <!-- Icon -->
              <div class="w-14 h-14 rounded-xl bg-[#a855f7]/10 border border-[#a855f7]/20 flex items-center justify-center mb-5 group-hover:bg-[#a855f7]/20 transition-colors">
                {item.icon === 'terminal' && (
                  <svg class="w-7 h-7 text-[#a855f7]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                    <polyline points="8 12 11 15 8 18"></polyline>
                    <line x1="14" y1="18" x2="18" y2="18"></line>
                  </svg>
                )}
                {item.icon === 'briefcase' && (
                  <svg class="w-7 h-7 text-[#a855f7]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                    <path d="M16 7V5a4 4 0 00-8 0v2"></path>
                  </svg>
                )}
                {item.icon === 'megaphone' && (
                  <svg class="w-7 h-7 text-[#a855f7]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 11l18-5v12L3 13v-2z"></path>
                    <path d="M11.6 16.8a3 3 0 11-5.8-1.6"></path>
                  </svg>
                )}
              </div>

              <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
              <p class="text-sm text-[#b0b0c0] leading-relaxed mb-6 flex-grow">{item.description}</p>

              <!-- CTA -->
              <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#a855f7]/10 border border-[#a855f7]/30 text-[#a855f7] text-sm font-medium rounded-full group-hover:bg-[#a855f7] group-hover:text-[#0a0a0f] transition-all duration-300">
                {item.cta}
                <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BOTTOM CTA: BOT-CAMP                          -->
  <!-- ============================================ -->
  <section class="py-16 mx-4">
    <div class="container mx-auto max-w-4xl p-8 md:p-12 border border-white/[0.08] bg-white/[0.03] backdrop-blur-xl rounded-2xl">
      <div class="text-center">
        <span class="inline-block px-4 py-2 border border-[#a855f7] text-[#a855f7] text-sm font-mono mb-6">הכשרה מקצועית</span>
        <h2 class="text-2xl md:text-3xl font-black mb-4">רוצים ללמוד לעומק?</h2>
        <p class="text-[#d0d0e0] text-lg mb-8 max-w-2xl mx-auto">
          הצטרפו להכשרת Bot-Camp — תוכנית מקצועית למפתחי סוכני AI ואוטומציות עסקיות,
          בליווי אקדמי של היחידה ללימודי חוץ באוניברסיטת חיפה.
        </p>
        <a
          href="/academy/"
          class="inline-flex items-center gap-3 px-8 py-4 bg-[#a855f7] text-[#0a0a0f] font-mono font-bold uppercase tracking-wider hover:shadow-[0_0_30px_rgba(168,85,247,0.5)] transition-all rounded-xl"
        >
          למידע נוסף על ההכשרה
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
