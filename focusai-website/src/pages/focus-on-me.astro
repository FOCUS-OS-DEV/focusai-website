---
/**
 * Focus on ME — מרכז ההדרכה של Focus AI
 * Fun, approachable hub for tools, agents, guides, and skills
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisplayCards from '../components/ui/display-cards';
import GlowingCardsGrid from '../components/ui/glowing-cards-grid';

const pageTitle = "Focus on ME | מרכז ההדרכה של Focus AI";
const pageDescription = "הצעד הראשון שלכם לעולם ה-AI והאוטומציות. כלים, סוכנים, מדריכים חינמיים וחבילות סקילים, הכל במקום אחד.";

const guides = [
  {
    title: 'מדריך חינם: סוכן AI ב-N8N',
    description: 'בוגרי Bot-Camp משתפים תוצרים אמיתיים. הנדסת פרומפטים ובניית סוכן AI ראשון ב-n8n',
    href: '/webinar-n8n-agent',
    cta: 'לצפייה',
    image: 'https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_600,h_340,c_fill/v1771759834/ef5cf54c-d1cf-4937-8f7a-b398d5839a17_gnx5ey.png',
    tag: 'FREE',
  },
  {
    title: 'הדרכה: סוכני AI',
    description: 'בניית סוכן AI מאפס. מה זה, למה זה חשוב ואיך מתחילים',
    href: '/%D7%95%D7%95%D7%91%D7%99%D7%A0%D7%A8-%D7%91%D7%9E%D7%AA%D7%A0%D7%94-%D7%A1%D7%95%D7%9B%D7%A0%D7%99-%D7%91%D7%99%D7%A0%D7%94-%D7%9E%D7%9C%D7%90%D7%9B%D7%95%D7%AA%D7%99%D7%AA/',
    cta: 'לצפייה',
    image: 'https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_600,h_340,c_fill/v1769624611/Generated_Image_January_28_2026_-_8_23PM_as7psy.jpg',
    tag: 'FREE',
  },
  {
    title: 'הדרכה: אוטומציית תוכן',
    description: 'יצירת תוכן עם AI. מאפס ועד פוסט מוכן לפרסום',
    href: '/content-automation-course',
    cta: 'לצפייה',
    image: 'https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_600,h_340,c_fill/v1771764387/66f2db89-c663-40aa-8932-7cde61c5f22b_pskwxj.png',
    tag: 'FREE',
  },
];

const skills = [
  {
    title: '50 סקילים למפתחים + מדריך התקנה',
    description: 'סקילים ל-Claude Code למפתחים עם מדריך התקנה ראשונית מלא',
    href: '/claude-skills-he',
    cta: 'להורדה',
    image: 'https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_600,h_340,c_fill/v1772583498/focusai/skills-developers-card.png',
    tag: 'SKILLS',
  },
  {
    title: '50 סקילים למנהלים + מדריך התקנה',
    description: 'סקילים לניהול, אסטרטגיה ותכנון עם מדריך התקנה ראשונית',
    href: '/claude-skills-managers',
    cta: 'להורדה',
    image: 'https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_600,h_340,c_fill/v1772583505/focusai/skills-managers-card.png',
    tag: 'SKILLS',
  },
  {
    title: '50 סקילים לשיווק + מדריך התקנה',
    description: 'סקילים לתוכן, קמפיינים וסושיאל עם מדריך התקנה ראשונית',
    href: '/claude-skills-marketing',
    cta: 'להורדה',
    image: 'https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_600,h_340,c_fill/v1772583511/focusai/skills-marketing-card.png',
    tag: 'SKILLS',
  },
];

---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header slot="header" currentPath="/focus-on-me" />

  <div class="relative">

    <!-- ============================================ -->
    <!-- HERO with background image                    -->
    <!-- ============================================ -->
    <section class="relative pt-32 pb-16 overflow-hidden">
      <!-- Background image -->
      <div class="absolute inset-0 z-0">
        <img
          src="https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_1600/v1772716345/focusai/focus-on-me-hero.jpg"
          alt=""
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0f]/60 via-[#0a0a0f]/70 to-[#0a0a0f]"></div>
      </div>

      <div class="container mx-auto px-4 relative z-10 max-w-5xl text-center">
        <h1 class="fom-hero-title text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black mb-6 leading-[0.95]">
          <span class="block text-[#f5f5fa]">Focus on</span>
          <span class="block fom-gradient-text">ME</span>
        </h1>

        <p class="text-lg md:text-xl text-[#d0d0e0] max-w-2xl mx-auto leading-relaxed mb-2">
          מרכז ההדרכה של Focus AI
        </p>
        <p class="text-base text-[#b0b0c0]/80 max-w-xl mx-auto leading-relaxed">
          הצעד הראשון שלכם לעולם הבינה המלאכותית והאוטומציות.
          <span class="text-[#c084fc]">בקצב שלכם, בדרך שלכם.</span>
        </p>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- TOOLS & AGENTS (stacked display cards)        -->
    <!-- ============================================ -->
    <section class="relative pb-10">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="flex items-center gap-3 mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
          <span class="font-mono text-xs text-[#b0b0c0]/60 uppercase tracking-wider">כלים וסוכנים</span>
        </div>

        <div class="flex min-h-[320px] w-full items-center justify-center py-8">
          <div class="w-full max-w-3xl">
            <DisplayCards client:load />
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- GUIDES & WEBINARS (image cards)               -->
    <!-- ============================================ -->
    <section class="relative pb-10">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
          <span class="font-mono text-xs text-[#b0b0c0]/60 uppercase tracking-wider">מדריכים והדרכות</span>
        </div>

        <GlowingCardsGrid client:load items={guides} />
      </div>
    </section>

    <!-- ============================================ -->
    <!-- CLAUDE CODE SKILLS                            -->
    <!-- ============================================ -->
    <section class="relative pt-4 pb-20">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7] animate-pulse"></span>
          <span class="font-mono text-xs text-[#b0b0c0]/60 uppercase tracking-wider">חבילות סקילים</span>
        </div>

        <GlowingCardsGrid client:load items={skills.map(s => ({ ...s, tagColor: 'neutral' as const }))} />
      </div>
    </section>

    <!-- ============================================ -->
    <!-- BOTTOM CTA: BOT-CAMP                          -->
    <!-- ============================================ -->
    <section class="pb-20 px-4">
      <div class="container mx-auto max-w-4xl p-8 md:p-12 border border-white/[0.08] bg-white/[0.03] backdrop-blur-xl rounded-2xl">
        <div class="text-center">
          <h2 class="text-2xl md:text-3xl font-black mb-4">רוצים ללמוד לעומק?</h2>
          <p class="text-[#d0d0e0] text-lg mb-8 max-w-2xl mx-auto">
            הצטרפו להכשרת Bot-Camp, תוכנית מקצועית למפתחי סוכני AI ואוטומציות עסקיות,
            בליווי אקדמי של היחידה ללימודי חוץ באוניברסיטת חיפה.
          </p>
          <a
            href="/academy/"
            class="inline-flex items-center gap-3 px-8 py-4 bg-[#a855f7] text-[#0a0a0f] font-mono font-bold uppercase tracking-wider hover:shadow-[0_0_30px_rgba(168,85,247,0.5)] transition-all rounded-xl"
          >
            למידע נוסף על ההכשרה
          </a>
        </div>
      </div>
    </section>

  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .fom-gradient-text {
    background: linear-gradient(135deg, #a855f7, #c084fc, #e879f9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 60px rgba(168, 85, 247, 0.5));
  }

  .fom-hero-title {
    letter-spacing: -0.03em;
  }

</style>
