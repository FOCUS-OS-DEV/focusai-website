      playing=false;updateIcon();
      var vol=audio.volume;
      var fade=setInterval(function(){
        vol=Math.max(vol-0.03,0);
        audio.volume=vol;
        if(vol<=0){clearInterval(fade);audio.pause();}
      },50);
    }
    function updateIcon(){
      wave1.style.opacity=playing?'1':'0.2';
      wave2.style.opacity=playing?'1':'0.2';
      btn.style.borderColor=playing?'rgba(200,100,60,.5)':'rgba(200,100,60,.25)';
    }
    fadeIn();
    document.addEventListener('click',function(e){
      if(e.target.closest('#audioToggle')) return;
      if(!playing) fadeIn();
    },{once:true});
    btn.addEventListener('click',function(e){
      e.stopPropagation();
      if(playing) fadeOut(); else fadeIn();
    });
    updateIcon();
  })();
  </script>

  <!-- ── Typewriter scripts ── -->
  <script>
    // ── Rotating terminal jokes — manager flavor ──
    const jokes = [
      "/strategic-plan → תוכנית שנתית מלאה עם יעדים, יוזמות ו-KPIs.",
      "/investor-pitch → מצגת משקיעים ב-12 שקפים. עם תשובות לשאלות הקשות.",
      "/performance-review → ביקורת ביצועים שמדברת על אנשים, לא על מספרים.",
      "/okr-design → OKRs שהצוות מאמין בהם. לא רק מכיר אותם.",
      "/meeting-summary → מהפגישה לסיכום עם משימות בשניות. לא ימים.",
      "/business-case → תיק עסקי שמשכנע דירקטוריון. עם מספרים.",
      "/decision-framework → מסגרת לקבלת החלטות קשות. בהירה ומתועדת.",
      "/metrics-dashboard → דשבורד KPI שמספר סיפור. לא רק מציג נתונים.",
    ];
    const twEl = document.getElementById('hero-tw');
    if (twEl) {
      let mi = 0, ci = 0, del = false;
      function twTick() {
        const msg = jokes[mi];
        if (!del) {
          if (ci < msg.length) { ci++; twEl.textContent = msg.slice(0, ci); setTimeout(twTick, 36); }
          else setTimeout(() => { del = true; twTick(); }, 3200);
        } else {
          if (ci > 0) { ci--; twEl.textContent = msg.slice(0, ci); setTimeout(twTick, 16); }
          else { del = false; mi = (mi + 1) % jokes.length; setTimeout(twTick, 280); }
        }
      }
      twTick();
    }

    // ── H1 one-shot typewriter ──
    const l1El = document.getElementById('h1-l1');
    const brEl = document.getElementById('h1-br');
    const l2El = document.getElementById('h1-l2');
    if (l1El && l2El) {
      const t1 = '60 סקילים למנהלים.';
      const t2 = 'במתנה.';
      let i = 0;
      function typeL1() {
        l1El.textContent = t1.slice(0, ++i);
        if (i < t1.length) setTimeout(typeL1, 36);
        else { brEl.style.display = ''; i = 0; setTimeout(typeL2, 180); }
      }
      function typeL2() {
        l2El.textContent = t2.slice(0, ++i);
        if (i < t2.length) setTimeout(typeL2, 68);
        else l2El.classList.add('done');
      }
      setTimeout(typeL1, 600);
    }
  </script>
