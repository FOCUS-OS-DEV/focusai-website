  <script is:inline>
    const WEBHOOK_URL = 'https://focusai.app.n8n.cloud/webhook/skills-dev';

    // ── Cookie consent ──
    const COOKIE_KEY = 'focusai_cookie_consent_skills';
    function hideCookieBanner() {
      const b = document.getElementById('cookie-banner');
      if (b) b.classList.remove('visible');
    }
    function saveConsent(type) {
      try { localStorage.setItem(COOKIE_KEY, JSON.stringify({ type, ts: Date.now() })); } catch(e) {}
      hideCookieBanner();
    }
    if (!localStorage.getItem(COOKIE_KEY)) {
      document.getElementById('cookie-banner')?.classList.add('visible');
    }
    document.getElementById('cookie-accept')?.addEventListener('click', () => saveConsent('all'));
    document.getElementById('cookie-essential')?.addEventListener('click', () => saveConsent('essential'));

    // ── Form helpers ──
    function field(wrap, name) { return wrap.querySelector(`[data-field="${name}"]`); }

    async function submitForm(wrap, successEl) {
      const firstNameEl = field(wrap, 'firstName');
      const lastNameEl  = field(wrap, 'lastName');
      const phoneEl     = field(wrap, 'phone');
      const emailEl     = field(wrap, 'email');
      const consultEl   = field(wrap, 'consultant');
      const privacyEl   = field(wrap, 'privacy');

      // Clear errors
      [firstNameEl, phoneEl, emailEl].forEach(el => el && el.classList.remove('error'));
      if (privacyEl) privacyEl.closest('.consult-row').style.borderColor = '';

      let valid = true;
      if (!firstNameEl.value.trim()) { firstNameEl.classList.add('error'); firstNameEl.focus(); valid = false; }

      // Israeli mobile: 10 digits, starts with 05x–09x
      const phoneClean = (phoneEl.value || '').replace(/[-\s]/g, '');
      if (!/^0[5-9]\d{7,8}$/.test(phoneClean)) {
        phoneEl.classList.add('error');
        if (valid) phoneEl.focus();
        valid = false;
      }

      if (!emailEl.value.trim() || !emailEl.value.includes('@')) { emailEl.classList.add('error'); if (valid) emailEl.focus(); valid = false; }

      // Privacy required (תיקון 13)
      if (privacyEl && !privacyEl.checked) {
        privacyEl.closest('.consult-row').style.borderColor = '#c8643c';
        valid = false;
      }

      if (!valid) return;

      const btn = wrap.querySelector('.form-btn');
      btn.textContent = 'שולח...';
      btn.disabled = true;

      const payload = {
        firstName:  firstNameEl.value.trim(),
        lastName:   lastNameEl ? lastNameEl.value.trim() : '',
        phone:      phoneClean,
        email:      emailEl.value.trim(),
        consultant: String(consultEl ? consultEl.checked : false),
        source:     'claude-skills-he',
        timestamp:  new Date().toISOString()
      };

      try {
        await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
      } catch (e) { /* silent fail */ }

      window.location.href = '/claude-skills-thank-you/';
    }

    document.getElementById('form-submit').addEventListener('click', () => {
      submitForm(document.getElementById('form-area'), document.getElementById('form-success'));
    });
    document.getElementById('form-submit-2').addEventListener('click', () => {
      submitForm(document.getElementById('form-area-2'), document.getElementById('form-success-2'));
    });

    // FAQ
    document.querySelectorAll('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(i => {
          i.classList.remove('open');
          i.querySelector('.faq-toggle').textContent = '[+]';
        });
        if (!isOpen) {
          item.classList.add('open');
          btn.querySelector('.faq-toggle').textContent = '[-]';
        }
      });
    });
  </script>

