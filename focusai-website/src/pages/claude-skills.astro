---
/**
 * Claude Code Skills Bundle — Landing Page A (Primary)
 * Design: Terminal window aesthetic
 * Route: /claude-skills/
 */
import Analytics from '../components/Analytics.astro';
import Tracker from '../components/Tracker.astro';
import AnalyticsBody from '../components/AnalyticsBody.astro';
---
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Ultimate Claude Code Skills Bundle · 50 Professional Skills</title>
  <meta name="description" content="50 pre-built Claude Code skills that handle real developer work. Code reviews, security audits, testing, architecture. Structured systems that produce polished output every time.">
  <meta name="robots" content="noindex">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://focusai.co.il/claude-skills/">
  <meta property="og:title" content="The Ultimate Claude Code Skills Bundle">
  <meta property="og:description" content="50 professional skills for Claude Code. Code review, security audits, debugging, architecture, testing. Installed in 60 seconds.">
  <meta property="og:image" content="https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_1200/v1765302030/focusai-og-image.png">

  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="icon" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <meta name="theme-color" content="#e0dfd7">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">

  <Analytics slot="head" />
  <Tracker />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #dddcd4;
      --bg-dark: #c8c7bf;
      --win-bg:  #ffffff;
      --win-bar: #d4d3cb;
      --text:    #1a1a14;
      --muted:   #55554e;
      --faint:   #888880;
      --orange:  #c8643c;
      --orange-h:#b8542c;
      --border:  #c8c7bf;
      --card-bg: #f8f8f4;
      --mono:    'JetBrains Mono', 'Fira Code', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--mono);
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── CRT scanlines ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.015) 2px,
        rgba(0,0,0,0.015) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    /* ── Terminal window ── */
    .term {
      max-width: 900px;
      margin: 0 auto;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 4px 24px rgba(0,0,0,0.1);
    }
    .term-bar {
      background: var(--win-bar);
      padding: 10px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 1px solid var(--border);
    }
    .dots { display: flex; gap: 7px; }
    .dot { width: 13px; height: 13px; border-radius: 50%; }
    .dot.r { background: #ff5f57; }
    .dot.y { background: #ffbd2e; }
    .dot.g { background: #28c840; }
    .term-cmd { font-size: 12px; color: var(--muted); }
    .term-body { background: var(--win-bg); padding: 40px 48px 48px; }

    /* ── Container ── */
    .wrap { max-width: 960px; margin: 0 auto; padding: 0 24px; }

    /* ── Sections ── */
    section { padding: 72px 24px; }
    section:first-of-type { padding-top: 0; }

    /* ── Typography ── */
    h1 { font-size: clamp(36px, 5.5vw, 64px); font-weight: 800; line-height: 1.1; letter-spacing: -0.5px; }
    h2 { font-size: clamp(26px, 3.5vw, 42px); font-weight: 800; line-height: 1.15; margin-bottom: 16px; }
    h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    p  { font-size: 15px; color: var(--muted); line-height: 1.9; }
    .orange { color: var(--orange); }
    .small-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 14px;
    }

    /* ── Button ── */
    .btn {
      display: inline-block;
      background: var(--orange);
      color: #fff;
      font-family: var(--mono);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 18px 40px;
      border-radius: 8px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(200,100,60,0.3);
      transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
    }
    .btn:hover { background: var(--orange-h); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(200,100,60,0.4); }
    .btn-wrap { text-align: center; margin-top: 40px; }
    .btn-full { display: block; width: 100%; text-align: center; padding: 20px; }

    /* ── Brand tag ── */
    .brand-tag {
      display: inline-block;
      border: 1px solid var(--orange);
      color: var(--orange);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 8px 24px;
      border-radius: 4px;
      margin-bottom: 28px;
    }

    /* ─────────────────── HERO ─────────────────── */
    #hero {
      text-align: center;
      padding: 80px 24px 80px;
    }
    #hero h1 { margin-bottom: 24px; }
    #hero p { max-width: 640px; margin: 0 auto 40px; font-size: 16px; }
    .sub-cta { font-size: 13px; color: var(--faint); margin-top: 16px; }
    .sub-cta span { margin: 0 6px; }

    /* ─────────────────── STEPS ─────────────────── */
    .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px; }
    .step-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 32px 24px;
      text-align: center;
    }
    .step-num { font-size: 42px; font-weight: 800; color: var(--orange); line-height: 1; margin-bottom: 16px; }
    .step-card h3 { font-size: 15px; margin-bottom: 12px; }
    .step-card p { font-size: 13px; }
    .step-card code { color: var(--orange); background: rgba(200,100,60,0.08); padding: 1px 5px; border-radius: 3px; font-size: 12px; }

    /* ─────────────────── TARGET ─────────────────── */
    .target-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 32px; }
    .target-card {
      background: var(--win-bg);
      border: 1px solid var(--border);
      border-left: 3px solid var(--orange);
      border-radius: 8px;
      padding: 24px 20px;
    }
    .target-icon { font-size: 24px; margin-bottom: 12px; }
    .target-card h3 { font-size: 14px; }
    .target-card p { font-size: 13px; }

    /* ─────────────────── LS LISTING ─────────────────── */
    .ls-list { margin-top: 28px; }
    .ls-row {
      display: flex;
      align-items: baseline;
      gap: 10px;
      padding: 7px 0;
      font-size: 14px;
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .ls-row:last-child { border-bottom: none; }
    .ls-tree { color: var(--faint); flex-shrink: 0; }
    .ls-icon { flex-shrink: 0; }
    .ls-folder { color: var(--orange); font-weight: 700; flex-shrink: 0; }
    .ls-files { color: var(--muted); font-size: 13px; }
    .ls-ellipsis { color: var(--faint); }

    /* ─────────────────── BLOCKQUOTES ─────────────────── */
    .bq-list { display: flex; flex-direction: column; gap: 0; margin-top: 32px; }
    .bq-item {
      border-left: 3px solid var(--orange);
      padding: 20px 24px;
      background: var(--card-bg);
      margin-bottom: 16px;
      border-radius: 0 6px 6px 0;
    }
    .bq-item p { font-size: 14px; line-height: 1.85; color: var(--muted); }
    .bq-item p strong { color: var(--text); }
    .bq-item p a, .bq-item p .hl { color: var(--orange); }

    /* ─────────────────── PRICING ─────────────────── */
    .price-box {
      border: 1px solid var(--orange);
      border-radius: 10px;
      padding: 36px 40px;
      margin-top: 32px;
    }
    .price-box-label { font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: var(--orange); text-align: center; margin-bottom: 28px; }
    .value-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
      font-size: 14px;
    }
    .value-row:last-of-type { border-bottom: 2px solid var(--text); }
    .value-name { color: var(--muted); }
    .value-price { color: var(--faint); text-decoration: line-through; font-size: 13px; }
    .value-total { color: var(--text); font-weight: 700; }
    .value-total-price { color: var(--text); font-weight: 700; }
    .price-amount { font-size: 64px; font-weight: 800; color: var(--orange); text-align: center; line-height: 1; margin: 32px 0 8px; }
    .price-note { text-align: center; font-size: 13px; color: var(--faint); margin-bottom: 28px; }

    /* ─────────────────── FAQ ─────────────────── */
    .faq-list { margin-top: 28px; }
    .faq-item { border-bottom: 1px solid var(--border); }
    .faq-q {
      width: 100%;
      display: flex;
      align-items: center;
      padding: 16px 0;
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--mono);
      font-size: 14px;
      gap: 12px;
      text-align: left;
    }
    .faq-arrow { color: var(--orange); flex-shrink: 0; font-weight: 700; }
    .faq-text { color: var(--orange); flex: 1; text-align: center; }
    .faq-toggle { color: var(--muted); flex-shrink: 0; font-size: 13px; }
    .faq-a {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .faq-item.open .faq-a { max-height: 500px; }
    .faq-a-inner { padding: 4px 0 20px 26px; font-size: 14px; color: var(--muted); line-height: 1.85; }

    /* ─────────────────── FINAL CTA ─────────────────── */
    .final-badge {
      display: inline-block;
      border: 1px solid var(--border);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      padding: 8px 20px;
      border-radius: 4px;
      margin-bottom: 28px;
    }

    /* ─────────────────── FOOTER ─────────────────── */
    footer {
      padding: 40px 24px;
      text-align: center;
      border-top: 1px solid var(--border);
    }
    footer a { color: var(--muted); text-decoration: none; font-size: 13px; }
    footer a:hover { color: var(--orange); }
    .footer-links { display: flex; justify-content: center; gap: 24px; margin-bottom: 12px; flex-wrap: wrap; }
    .footer-copy { font-size: 12px; color: var(--faint); }

    /* ─────────────────── RESPONSIVE ─────────────────── */
    @media (max-width: 720px) {
      .term-body { padding: 28px 24px 36px; }
      .steps-grid { grid-template-columns: 1fr; }
      .target-grid { grid-template-columns: 1fr; }
      .price-box { padding: 28px 24px; }
    }
    @media (max-width: 480px) {
      #hero h1 { font-size: 32px; }
      .price-amount { font-size: 48px; }
    }
    /* ── Blinking cursor ── */
    .cursor {
      display: inline-block;
      width: 10px;
      height: 0.82em;
      background: currentColor;
      vertical-align: text-bottom;
      border-radius: 1px;
      animation: cursor-blink 1.1s step-end infinite;
    }
    @keyframes cursor-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
  </style>
</head>
<body>
  <AnalyticsBody />

  <!-- ─────────── HERO ─────────── -->
  <section id="hero">
    <div style="max-width:760px;margin:0 auto;">
      <p class="small-label">Built on official Anthropic docs</p>
      <div class="brand-tag">&gt; Focus AI</div>
      <h1>
        The Ultimate<br>
        <span class="orange">Claude Code Skills Bundle.<span class="cursor" aria-hidden="true"></span></span>
      </h1>
      <p>50 pre-built skills that turn Claude Code into your senior developer pair. Code reviews, security audits, testing, architecture, structured systems that produce polished, ready-to-use output every time.</p>
      <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin:18px 0 28px;">
        <span style="display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.13);border-radius:999px;padding:7px 16px;font-size:13px;font-weight:600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 50 professional skills (ZIP)</span>
        <span style="display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.13);border-radius:999px;padding:7px 16px;font-size:13px;font-weight:600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Auto-install script</span>
        <span style="display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.13);border-radius:999px;padding:7px 16px;font-size:13px;font-weight:600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Full installation guide</span>
      </div>
      <a href="https://focusai.gumroad.com/l/claude-skills" class="btn">Get the Bundle · $15</a>
      <p class="sub-cta">One-time purchase <span>·</span> Instant download <span>·</span> 30-day guarantee</p>
    </div>
  </section>

  <!-- ─────────── INSTALL ─────────── -->
  <section>
    <div class="wrap">
      <div class="term">
        <div class="term-bar">
          <div class="dots"><span class="dot r"></span><span class="dot y"></span><span class="dot g"></span></div>
          <span class="term-cmd">claude@skills ~ % ./install.sh</span>
        </div>
        <div class="term-body">
          <h2>Up and Running in 60 Seconds.</h2>
          <p>The Claude Code Skills Bundle gives you 50 pre-built skills that handle real developer work. Structured systems that produce polished, ready-to-use output every time.</p>

          <div class="steps-grid">
            <div class="step-card">
              <div class="step-num">1</div>
              <h3>Download</h3>
              <p>Grab the skills folder and drop it into <code>~/.claude/skills/</code>. Setup guide included.</p>
            </div>
            <div class="step-card">
              <div class="step-num">2</div>
              <h3>Open Claude Code</h3>
              <p>Run <code>claude</code> in any project. Skills are ready immediately, no config required.</p>
            </div>
            <div class="step-card">
              <div class="step-num">3</div>
              <h3>Invoke</h3>
              <p>Type <code>/skill-name</code> in Claude Code. Or just describe what you need. Claude detects the right skill.</p>
            </div>
          </div>

          <div class="btn-wrap">
            <a href="https://focusai.gumroad.com/l/claude-skills" class="btn">Get the Bundle · $15</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── TARGET AUDIENCE ─────────── -->
  <section>
    <div class="wrap">
      <div class="term">
        <div class="term-bar">
          <div class="dots"><span class="dot r"></span><span class="dot y"></span><span class="dot g"></span></div>
          <span class="term-cmd">claude@skills ~ % cat target-users.md</span>
        </div>
        <div class="term-body">
          <h2>Built for Developers Who Ship Things.</h2>
          <p>If you write code and want AI that actually keeps up, this bundle was made for you.</p>

          <div class="target-grid">
            <div class="target-card">
              <div class="target-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
              <h3>Solo Developers</h3>
              <p>You're the architect, reviewer, and QA team. These skills handle every phase of the dev cycle so you can focus on building.</p>
            </div>
            <div class="target-card">
              <div class="target-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
              <h3>Dev Teams</h3>
              <p>Code reviews, PR descriptions, architecture decisions. Consistent quality across every team member, every time.</p>
            </div>
            <div class="target-card">
              <div class="target-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="12" y1="2" x2="12" y2="22"/></svg></div>
              <h3>Tech Leads</h3>
              <p>Security audits, dependency reviews, architecture documentation. Handled in minutes instead of hours.</p>
            </div>
            <div class="target-card">
              <div class="target-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg></div>
              <h3>Freelance Developers</h3>
              <p>Client code reviews, onboarding new codebases, writing docs. The entire workflow side of client work, done fast.</p>
            </div>
          </div>

          <div class="btn-wrap">
            <a href="https://focusai.gumroad.com/l/claude-skills" class="btn">Get the Bundle · $15</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── SKILLS LISTING ─────────── -->
  <section>
    <div class="wrap">
      <div class="term">
        <div class="term-bar">
          <div class="dots"><span class="dot r"></span><span class="dot y"></span><span class="dot g"></span></div>
          <span class="term-cmd">claude@skills ~ % ls -la skills/</span>
        </div>
        <div class="term-body">
          <h2>50 Skills. Every Part of Your Codebase.</h2>
          <p>Each skill asks the right questions and delivers polished, ready-to-use output. Here's a taste.</p>

          <div class="ls-list">
            <div class="ls-row"><span class="ls-tree">├──</span><span class="ls-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></span><span class="ls-folder">code-quality/</span><span class="ls-files">code-review, security-review, performance-review, refactor, clean-code <span class="ls-ellipsis">…</span></span></div>
            <div class="ls-row"><span class="ls-tree">├──</span><span class="ls-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></span><span class="ls-folder">debugging/</span><span class="ls-files">debug-smart, fix-error, trace-bug, memory-leak, async-debug <span class="ls-ellipsis">…</span></span></div>
            <div class="ls-row"><span class="ls-tree">├──</span><span class="ls-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></span><span class="ls-folder">testing/</span><span class="ls-files">write-tests, edge-cases, mock-generate, e2e-tests, test-coverage <span class="ls-ellipsis">…</span></span></div>
