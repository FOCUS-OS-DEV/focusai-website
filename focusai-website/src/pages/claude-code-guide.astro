---
/**
 * Claude Code Installation & Setup Guide — Hebrew (Unified)
 * Accessible via email link + focusai.co.il/claude-code-guide/
 * Route: /claude-code-guide/
 * Consolidates dev/managers/marketing guides into one comprehensive guide
 */
import Analytics from '../components/Analytics.astro';
import AnalyticsBody from '../components/AnalyticsBody.astro';
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>מדריך התקנה והפעלה של Claude Code | Focus AI</title>
  <meta name="description" content="מדריך מלא בעברית להתקנת Claude Code: סביבת עבודה, התקנה על Windows ו-Mac, הגדרת API, התקנת סקילים וטיפים למתחילים.">
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Heebo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <Analytics slot="head" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #dddcd4;
      --win-bg:  #ffffff;
      --win-bar: #d4d3cb;
      --text:    #1a1a14;
      --muted:   #55554e;
      --faint:   #888880;
      --orange:  #c8643c;
      --orange-h:#b8542c;
      --border:  #c8c7bf;
      --card-bg: #f8f8f4;
      --mono:    'JetBrains Mono', monospace;
      --hebrew:  'Heebo', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--hebrew);
      background-color: var(--bg);
      background-image: radial-gradient(circle at 20% 20%, rgba(200,100,60,0.03) 0%, transparent 50%),
                         radial-gradient(circle at 80% 80%, rgba(200,100,60,0.02) 0%, transparent 50%);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── Reading progress bar ── */
    .progress-bar {
      position: fixed;
      top: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--orange), #e8a040);
      width: 0%;
      z-index: 9999;
      transition: width 0.1s linear;
      box-shadow: 0 0 8px rgba(200,100,60,0.4);
    }

    /* ── Scroll reveal ── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Layout ── */
    .wrap { max-width: 780px; margin: 0 auto; padding: 0 24px; }

    /* ── Topbar ── */
    .topbar {
      background: var(--win-bar);
      border-bottom: 1px solid var(--border);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .topbar a { color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 600; }
    .topbar a:hover { color: var(--orange); }

    /* ── Hero ── */
    .hero {
      text-align: center;
      padding: 56px 24px 40px;
      position: relative;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 400px;
      background: radial-gradient(ellipse, rgba(200,100,60,0.08) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    .hero > * { position: relative; z-index: 1; }
    .hero-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
    }
    .hero h1 {
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 900;
      line-height: 1.15;
      margin-bottom: 16px;
      color: var(--text);
    }
    .hero-sub {
      font-size: 16px;
      color: var(--muted);
      max-width: 540px;
      margin: 0 auto;
    }

    /* ── Blinking cursor (RTL-safe) ── */
    .headline-cursor { white-space: nowrap; }
    .headline-cursor::after {
      content: '';
      display: inline-block;
      width: 3px;
      height: 0.85em;
      background: currentColor;
      vertical-align: -0.1em;
      border-radius: 1px;
      margin-inline-start: 4px;
      animation: cursor-blink 1.1s step-end infinite;
    }
    @keyframes cursor-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    @keyframes hero-in {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero { animation: hero-in 0.55s ease-out both; }

    /* ── Guide body ── */
    .guide-body {
      background: var(--win-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
      margin: 0 24px 40px;
      max-width: 780px;
      margin-left: auto;
      margin-right: auto;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
    }

    /* Terminal-style tab bar */
    .doc-bar {
      background: var(--win-bar);
      padding: 10px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
      direction: ltr;
    }
    .doc-dot { width: 12px; height: 12px; border-radius: 50%; }
    .doc-dot.r { background: #ff5f57; }
    .doc-dot.y { background: #ffbd2e; }
    .doc-dot.g { background: #28c840; }
    .doc-title { font-family: var(--mono); font-size: 12px; color: var(--muted); margin-right: auto; }

    .doc-content { padding: 40px 48px 56px; }

    /* Typography inside guide */
    .doc-content h2 {
      font-size: clamp(18px, 3vw, 26px);
      font-weight: 800;
      margin: 48px 0 16px;
      padding-top: 32px;
      border-top: 1px solid var(--border);
      color: var(--text);
    }
    .doc-content h2:first-child { border-top: none; padding-top: 0; margin-top: 0; }
    .doc-content h3 {
      font-size: 15px;
      font-weight: 700;
      margin: 28px 0 10px;
      color: var(--text);
    }
    .doc-content p { font-size: 15px; color: var(--muted); margin-bottom: 16px; line-height: 1.8; }
    .doc-content strong { color: var(--text); }
    .doc-content ul { margin: 0 0 16px 0; padding-right: 20px; }
    .doc-content li { font-size: 15px; color: var(--muted); margin-bottom: 8px; line-height: 1.7; }
    .doc-content ol { margin: 0 0 16px 0; padding-right: 20px; }
    .doc-content ol li { font-size: 15px; color: var(--muted); margin-bottom: 8px; }
    .doc-content a { color: var(--orange); text-decoration: none; }
    .doc-content a:hover { text-decoration: underline; }

    /* Step number */
    .step-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      background: linear-gradient(135deg, var(--orange), #e8884c);
      color: #fff;
      font-size: 14px;
      font-weight: 800;
      border-radius: 50%;
      margin-left: 10px;
      flex-shrink: 0;
      box-shadow: 0 2px 8px rgba(200,100,60,0.3);
      position: relative;
    }
    .step-num::after {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      border: 2px solid rgba(200,100,60,0.15);
    }

    /* Code blocks */
    .code-block {
      background: #1e1e2e;
      border-radius: 10px;
      padding: 16px 20px;
      margin: 12px 0 20px;
      direction: ltr;
      overflow-x: auto;
      position: relative;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .code-block::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(200,100,60,0.3), transparent);
    }
    .code-block code {
      font-family: var(--mono);
      font-size: 13px;
      color: #cdd6f4;
      line-height: 1.7;
      white-space: pre;
    }
    .code-block .comment { color: #6c7086; }
    .code-block .cmd { color: #89dceb; }
    .code-block .string { color: #a6e3a1; }

    /* Copy button */
    .code-copy {
      position: absolute;
      top: 8px;
      left: 8px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 11px;
      color: #888;
      cursor: pointer;
      font-family: var(--mono);
      transition: all 0.2s;
      z-index: 1;
    }
    .code-copy:hover { background: rgba(255,255,255,0.15); color: #ccc; }
    .code-copy.copied { color: #a6e3a1; border-color: rgba(166,227,161,0.3); }

    /* Inline code */
    .ic {
      font-family: var(--mono);
      font-size: 13px;
      background: #eee;
      padding: 2px 6px;
      border-radius: 4px;
      color: #c8643c;
    }

    /* Table */
    .tbl {
      width: 100%;
      border-collapse: collapse;
      margin: 12px 0 24px;
      font-size: 14px;
    }
    .tbl th {
      background: var(--card-bg);
      padding: 10px 14px;
      text-align: right;
      font-weight: 700;
      border-bottom: 2px solid var(--border);
      color: var(--text);
    }
    .tbl td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      color: var(--muted);
      vertical-align: top;
    }
    .tbl tr:last-child td { border-bottom: none; }
    .tbl td:first-child { font-family: var(--mono); font-size: 12px; color: var(--orange); }

    /* Note/tip boxes */
    .note {
      background: linear-gradient(135deg, #fef9f0, #fdf5e6);
      border-right: 3px solid #e8a953;
      padding: 14px 18px;
      border-radius: 0 8px 8px 0;
      margin: 16px 0;
      font-size: 14px;
      color: var(--muted);
      box-shadow: 0 1px 4px rgba(0,0,0,0.03);
    }
    .note strong { color: #b8732c; }

    /* Warning box */
    .warning {
      background: linear-gradient(135deg, #fef0f0, #fde8e8);
      border-right: 3px solid #e85353;
      padding: 14px 18px;
      border-radius: 0 8px 8px 0;
      margin: 16px 0;
      font-size: 14px;
      color: var(--muted);
      box-shadow: 0 1px 4px rgba(0,0,0,0.03);
    }
    .warning strong { color: #c82c2c; }

    /* Screenshot image */
    .guide-img {
      width: 100%;
      border-radius: 8px;
      border: 1px solid var(--border);
      margin: 16px 0 20px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .guide-img-caption {
      font-size: 12px;
      color: var(--faint);
      text-align: center;
      margin: -12px 0 20px;
    }

    /* UI Mockup boxes */
    .ui-mockup {
      background: #f5f5f0;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      margin: 16px 0 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .ui-titlebar {
      background: #e8e7e0;
      padding: 8px 14px;
      font-size: 12px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid var(--border);
      direction: ltr;
    }
    .ui-titlebar-icon { font-size: 14px; }
    .ui-body { padding: 16px; }

    /* Windows search mockup */
    .win-search {
      background: #2d2d2d;
      border-radius: 10px;
      overflow: hidden;
      margin: 16px 0 20px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      direction: ltr;
    }
    .win-search-bar {
      background: #3c3c3c;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .win-search-bar input {
      background: transparent;
      border: none;
      color: #fff;
      font-family: 'Segoe UI', sans-serif;
      font-size: 14px;
      flex: 1;
      outline: none;
    }
    .win-search-icon { color: #888; font-size: 16px; }
    .win-search-result {
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      background: #383838;
      border-top: 1px solid #444;
      cursor: default;
    }
    .win-search-result.highlighted {
      background: #0078d4;
    }
    .win-search-result .sr-icon {
      width: 32px;
      height: 32px;
      background: #0078d4;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      color: #fff;
      flex-shrink: 0;
    }
    .win-search-result.highlighted .sr-icon { background: rgba(255,255,255,0.15); }
    .win-search-result .sr-text { font-family: 'Segoe UI', sans-serif; font-size: 13px; color: #eee; }
    .win-search-result .sr-sub { font-family: 'Segoe UI', sans-serif; font-size: 11px; color: #999; }
    .win-search-result.highlighted .sr-sub { color: rgba(255,255,255,0.7); }

    /* Link card */
    .link-card {
      display: flex;
      align-items: center;
      gap: 14px;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px 20px;
      margin: 16px 0 20px;
      text-decoration: none;
      transition: all 0.25s ease;
    }
    .link-card:hover { border-color: var(--orange); background: #fff; transform: translateX(-4px); box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .link-card-icon {
      width: 46px;
      height: 46px;
      background: var(--orange);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .link-card-text { flex: 1; }
    .link-card-title { font-size: 14px; font-weight: 700; color: var(--text); }
    .link-card-url { font-family: var(--mono); font-size: 11px; color: var(--faint); }
    .link-card-arrow { font-size: 18px; color: var(--faint); transition: transform 0.2s; }
    .link-card:hover .link-card-arrow { transform: translateX(-4px); color: var(--orange); }

    /* OS Tabs */
    .os-tabs {
      display: flex;
      gap: 0;
      border-bottom: 2px solid var(--border);
      margin: 20px 0 0;
    }
    .os-tab {
      padding: 10px 20px;
      font-size: 14px;
      font-weight: 700;
      color: var(--faint);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      transition: all 0.15s;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      font-family: var(--hebrew);
    }
    .os-tab.active {
      color: var(--orange);
      border-bottom-color: var(--orange);
    }
    .os-tab:hover { color: var(--orange); }
    .os-panel { display: none; padding: 20px 0 0; }
    .os-panel.active { display: block; }

    /* Skill list */
    .skill-table {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin: 12px 0 24px;
    }
    .skill-item {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px 14px;
      transition: all 0.2s ease;
    }
    .skill-item:hover { border-color: var(--orange); background: #fff; }
    .skill-cmd {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--orange);
      font-weight: 600;
      display: block;
      margin-bottom: 2px;
    }
    .skill-desc {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.4;
    }
    @media (max-width: 580px) {
      .skill-table { grid-template-columns: 1fr; }
      .doc-content { padding: 24px 16px 40px; }
      .hero { padding: 40px 16px 32px; }
      .hero::before { width: 300px; height: 200px; }
      .cta-block { padding: 40px 24px; border-radius: 12px; }
      .wa-block { padding: 28px 20px; }
      .link-card { padding: 12px 14px; gap: 10px; }
      .link-card-icon { width: 38px; height: 38px; }
      .back-to-top { bottom: 16px; left: 16px; width: 40px; height: 40px; }
      .guide-body { margin: 0 12px 32px; }
    }

    /* Download cards */
    .download-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
      margin: 16px 0 24px;
    }
    .download-card {
      background: var(--card-bg);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 24px 16px;
      text-align: center;
      transition: all 0.25s ease;
      position: relative;
      overflow: hidden;
    }
    .download-card::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      left: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--orange), #e8a040);
      opacity: 0;
      transition: opacity 0.25s;
    }
    .download-card:hover { border-color: var(--orange); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(200,100,60,0.12); }
    .download-card:hover::before { opacity: 1; }
    .download-card .dl-icon { font-size: 32px; margin-bottom: 10px; }
    .download-card .dl-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
    .download-card .dl-desc { font-size: 12px; color: var(--faint); margin-bottom: 14px; line-height: 1.4; }
    .download-card .dl-btn {
      display: inline-block;
      background: linear-gradient(135deg, var(--orange), #d4744c);
      color: #fff;
      font-family: var(--hebrew);
      font-size: 13px;
      font-weight: 700;
      padding: 9px 18px;
      border-radius: 8px;
      text-decoration: none;
      transition: all 0.2s;
      box-shadow: 0 2px 8px rgba(200,100,60,0.2);
    }
    .download-card .dl-btn:hover { background: linear-gradient(135deg, var(--orange-h), var(--orange)); color: #fff; box-shadow: 0 4px 12px rgba(200,100,60,0.3); }
    @media (max-width: 680px) {
      .download-grid { grid-template-columns: 1fr; }
    }

    /* ── CTA block ── */
    .cta-block {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
      border-radius: 16px;
      padding: 56px 40px;
      text-align: center;
      margin: 48px 0 0;
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(200,100,60,0.1);
    }
    .cta-block::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at center, rgba(200,100,60,0.06) 0%, transparent 50%);
      pointer-events: none;
    }
    .cta-block > * { position: relative; z-index: 1; }
    .cta-block h2 { color: #fff; font-size: clamp(20px, 4vw, 32px); margin-bottom: 12px; }
    .cta-block p { color: #9090a0; font-size: 15px; margin-bottom: 28px; max-width: 480px; margin-left: auto; margin-right: auto; }
    .btn-cta {
      display: inline-block;
      background: linear-gradient(135deg, var(--orange), #d87040);
      color: #fff !important;
      font-family: var(--hebrew);
      font-size: 16px;
      font-weight: 700;
      padding: 16px 40px;
      border-radius: 10px;
      text-decoration: none;
      text-align: center;
      line-height: 1.4;
      box-shadow: 0 4px 20px rgba(200,100,60,0.35);
      transition: all 0.25s ease;
    }
    .btn-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(200,100,60,0.45); color: #fff !important; }
    .cta-note { font-size: 12px; color: #606070; margin-top: 14px; }

    /* ── Disclaimer ── */
    .disclaimer {
      background: #f4f3ee;
      border: 1px solid var(--border);
      border-right: 4px solid var(--faint);
      border-radius: 8px;
      padding: 16px 20px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
      margin: 24px 0;
    }
    .disclaimer strong { color: var(--text); }

    /* ── WhatsApp Community ── */
    .wa-block {
      background: linear-gradient(135deg, #f4f3ee, #eef5ee);
      border: 1.5px solid rgba(37,211,102,0.25);
      border-radius: 16px;
      padding: 36px;
      text-align: center;
      margin: 48px 0 0;
      position: relative;
      overflow: hidden;
    }
    .wa-block::before {
      content: '';
      position: absolute;
      top: -30px;
      left: 50%;
      transform: translateX(-50%);
      width: 300px;
      height: 200px;
      background: radial-gradient(ellipse, rgba(37,211,102,0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    .wa-block > * { position: relative; z-index: 1; }
    .wa-block h2 { font-size: 20px; font-weight: 800; margin-bottom: 8px; }
    .wa-block p { font-size: 14px; color: var(--muted); margin-bottom: 20px; }
    .btn-wa {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, #25D366, #20bd5a);
      color: #fff;
      font-family: var(--hebrew);
      font-size: 15px;
      font-weight: 700;
      padding: 13px 30px;
      border-radius: 10px;
      text-decoration: none;
      transition: all 0.25s ease;
      box-shadow: 0 3px 12px rgba(37,211,102,0.25);
    }
