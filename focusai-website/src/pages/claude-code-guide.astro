---
/**
 * Claude Code Installation & Setup Guide — Hebrew (Unified)
 * Accessible via email link + focusai.co.il/claude-code-guide/
 * Route: /claude-code-guide/
 * Consolidates dev/managers/marketing guides into one comprehensive guide
 */
import Analytics from '../components/Analytics.astro';
import AnalyticsBody from '../components/AnalyticsBody.astro';
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>מדריך התקנה והפעלה של Claude Code | Focus AI</title>
  <meta name="description" content="מדריך מלא בעברית להתקנת Claude Code: סביבת עבודה, התקנה על Windows ו-Mac, הגדרת API, התקנת סקילים וטיפים למתחילים.">
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Heebo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <Analytics slot="head" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #dddcd4;
      --win-bg:  #ffffff;
      --win-bar: #d4d3cb;
      --text:    #1a1a14;
      --muted:   #55554e;
      --faint:   #888880;
      --orange:  #c8643c;
      --orange-h:#b8542c;
      --border:  #c8c7bf;
      --card-bg: #f8f8f4;
      --mono:    'JetBrains Mono', monospace;
      --hebrew:  'Heebo', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--hebrew);
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── Layout ── */
    .wrap { max-width: 780px; margin: 0 auto; padding: 0 24px; }

    /* ── Topbar ── */
    .topbar {
      background: var(--win-bar);
      border-bottom: 1px solid var(--border);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .topbar a { color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 600; }
    .topbar a:hover { color: var(--orange); }
    .topbar-lang { font-size: 12px; color: var(--faint); }

    /* ── Hero ── */
    .hero {
      text-align: center;
      padding: 56px 24px 40px;
    }
    .hero-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
    }
    .hero h1 {
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 900;
      line-height: 1.15;
      margin-bottom: 16px;
    }
    .hero-sub {
      font-size: 16px;
      color: var(--muted);
      max-width: 540px;
      margin: 0 auto;
    }

    /* ── Blinking cursor (RTL-safe) ── */
    .headline-cursor { white-space: nowrap; }
    .headline-cursor::after {
      content: '';
      display: inline-block;
      width: 3px;
      height: 0.85em;
      background: currentColor;
      vertical-align: -0.1em;
      border-radius: 1px;
      margin-inline-start: 4px;
      animation: cursor-blink 1.1s step-end infinite;
    }
    @keyframes cursor-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    @keyframes hero-in {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero { animation: hero-in 0.55s ease-out both; }

    /* ── Guide body ── */
    .guide-body {
      background: var(--win-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      margin: 0 24px 40px;
      max-width: 780px;
      margin-left: auto;
      margin-right: auto;
      overflow: hidden;
    }

    /* Terminal-style tab bar */
    .doc-bar {
      background: var(--win-bar);
      padding: 10px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
      direction: ltr;
    }
    .doc-dot { width: 12px; height: 12px; border-radius: 50%; }
    .doc-dot.r { background: #ff5f57; }
    .doc-dot.y { background: #ffbd2e; }
    .doc-dot.g { background: #28c840; }
    .doc-title { font-family: var(--mono); font-size: 12px; color: var(--muted); margin-right: auto; }

    .doc-content { padding: 40px 48px 56px; }

    /* Typography inside guide */
    .doc-content h2 {
      font-size: clamp(18px, 3vw, 26px);
      font-weight: 800;
      margin: 48px 0 16px;
      padding-top: 32px;
      border-top: 1px solid var(--border);
      color: var(--text);
    }
    .doc-content h2:first-child { border-top: none; padding-top: 0; margin-top: 0; }
    .doc-content h3 {
      font-size: 15px;
      font-weight: 700;
      margin: 28px 0 10px;
      color: var(--text);
    }
    .doc-content p { font-size: 15px; color: var(--muted); margin-bottom: 16px; line-height: 1.8; }
    .doc-content strong { color: var(--text); }
    .doc-content ul { margin: 0 0 16px 0; padding-right: 20px; }
    .doc-content li { font-size: 15px; color: var(--muted); margin-bottom: 8px; line-height: 1.7; }
    .doc-content ol { margin: 0 0 16px 0; padding-right: 20px; }
    .doc-content ol li { font-size: 15px; color: var(--muted); margin-bottom: 8px; }
    .doc-content a { color: var(--orange); text-decoration: none; }
    .doc-content a:hover { text-decoration: underline; }

    /* Step number */
    .step-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      background: var(--orange);
      color: #fff;
      font-size: 13px;
      font-weight: 800;
      border-radius: 50%;
      margin-left: 8px;
      flex-shrink: 0;
    }

    /* Code blocks */
    .code-block {
      background: #1e1e2e;
      border-radius: 8px;
      padding: 16px 20px;
      margin: 12px 0 20px;
      direction: ltr;
      overflow-x: auto;
    }
    .code-block code {
      font-family: var(--mono);
      font-size: 13px;
      color: #cdd6f4;
      line-height: 1.7;
      white-space: pre;
    }
    .code-block .comment { color: #6c7086; }
    .code-block .cmd { color: #89dceb; }
    .code-block .string { color: #a6e3a1; }

    /* Inline code */
    .ic {
      font-family: var(--mono);
      font-size: 13px;
      background: #eee;
      padding: 2px 6px;
      border-radius: 4px;
      color: #c8643c;
    }

    /* Table */
    .tbl {
      width: 100%;
      border-collapse: collapse;
      margin: 12px 0 24px;
      font-size: 14px;
    }
    .tbl th {
      background: var(--card-bg);
      padding: 10px 14px;
      text-align: right;
      font-weight: 700;
      border-bottom: 2px solid var(--border);
      color: var(--text);
    }
    .tbl td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      color: var(--muted);
      vertical-align: top;
    }
    .tbl tr:last-child td { border-bottom: none; }
    .tbl td:first-child { font-family: var(--mono); font-size: 12px; color: var(--orange); }

    /* Note/tip boxes */
    .note {
      background: #fef9f0;
      border-right: 3px solid #e8a953;
      padding: 12px 16px;
      border-radius: 0 6px 6px 0;
      margin: 16px 0;
      font-size: 14px;
      color: var(--muted);
    }
    .note strong { color: #b8732c; }

    /* Warning box */
    .warning {
      background: #fef0f0;
      border-right: 3px solid #e85353;
      padding: 12px 16px;
      border-radius: 0 6px 6px 0;
      margin: 16px 0;
      font-size: 14px;
      color: var(--muted);
    }
    .warning strong { color: #c82c2c; }

    /* Screenshot image */
    .guide-img {
      width: 100%;
      border-radius: 8px;
      border: 1px solid var(--border);
      margin: 16px 0 20px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .guide-img-caption {
      font-size: 12px;
      color: var(--faint);
      text-align: center;
      margin: -12px 0 20px;
    }

    /* UI Mockup boxes */
    .ui-mockup {
      background: #f5f5f0;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      margin: 16px 0 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .ui-titlebar {
      background: #e8e7e0;
      padding: 8px 14px;
      font-size: 12px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid var(--border);
      direction: ltr;
    }
    .ui-titlebar-icon { font-size: 14px; }
    .ui-body { padding: 16px; }

    /* Windows search mockup */
    .win-search {
      background: #2d2d2d;
      border-radius: 10px;
      overflow: hidden;
      margin: 16px 0 20px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      direction: ltr;
    }
    .win-search-bar {
      background: #3c3c3c;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .win-search-bar input {
      background: transparent;
      border: none;
      color: #fff;
      font-family: 'Segoe UI', sans-serif;
      font-size: 14px;
      flex: 1;
      outline: none;
    }
    .win-search-icon { color: #888; font-size: 16px; }
    .win-search-result {
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      background: #383838;
      border-top: 1px solid #444;
      cursor: default;
    }
    .win-search-result.highlighted {
      background: #0078d4;
    }
    .win-search-result .sr-icon {
      width: 32px;
      height: 32px;
      background: #0078d4;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      color: #fff;
      flex-shrink: 0;
    }
    .win-search-result.highlighted .sr-icon { background: rgba(255,255,255,0.15); }
    .win-search-result .sr-text { font-family: 'Segoe UI', sans-serif; font-size: 13px; color: #eee; }
    .win-search-result .sr-sub { font-family: 'Segoe UI', sans-serif; font-size: 11px; color: #999; }
    .win-search-result.highlighted .sr-sub { color: rgba(255,255,255,0.7); }

    /* Git installer mockup */
    .git-installer {
      background: #f0f0f0;
      border: 1px solid #ccc;
      border-radius: 4px;
      overflow: hidden;
      margin: 16px 0 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      direction: ltr;
    }
    .git-installer-title {
      background: #fff;
      padding: 8px 12px;
      font-family: 'Segoe UI', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: #333;
      border-bottom: 1px solid #ddd;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .git-installer-body { padding: 16px; }
    .git-checkbox {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 3px 0;
      font-family: 'Segoe UI', sans-serif;
      font-size: 12px;
      color: #333;
    }
    .git-checkbox .cb {
      width: 14px;
      height: 14px;
      border: 1px solid #999;
      border-radius: 2px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .git-checkbox .cb.checked { background: #fff; }
    .git-checkbox .cb.checked::after { content: '✓'; font-size: 11px; color: #333; }
    .git-dropdown {
      background: #fff;
      border: 1px solid #999;
      border-radius: 2px;
      padding: 6px 28px 6px 10px;
      font-family: 'Segoe UI', sans-serif;
      font-size: 12px;
      color: #333;
      margin: 8px 0;
      width: 100%;
      max-width: 400px;
      position: relative;
    }
    .git-dropdown::after {
      content: '▾';
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      color: #666;
    }
    .git-dropdown-option {
      padding: 5px 10px;
      font-family: 'Segoe UI', sans-serif;
      font-size: 12px;
      color: #333;
      border-bottom: 1px solid #eee;
    }
    .git-dropdown-option.selected {
      background: #0078d4;
      color: #fff;
    }

    /* Link card */
    .link-card {
      display: flex;
      align-items: center;
      gap: 14px;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 18px;
      margin: 16px 0 20px;
      text-decoration: none;
      transition: all 0.15s;
    }
    .link-card:hover { border-color: var(--orange); background: #fff; }
    .link-card-icon {
      width: 44px;
      height: 44px;
      background: var(--orange);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
    }
    .link-card-text { flex: 1; }
    .link-card-title { font-size: 14px; font-weight: 700; color: var(--text); }
    .link-card-url { font-family: var(--mono); font-size: 11px; color: var(--faint); }
    .link-card-arrow { font-size: 18px; color: var(--faint); }

    /* OS Tabs */
    .os-tabs {
      display: flex;
      gap: 0;
      border-bottom: 2px solid var(--border);
      margin: 20px 0 0;
    }
    .os-tab {
      padding: 10px 20px;
      font-size: 14px;
      font-weight: 700;
      color: var(--faint);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      transition: all 0.15s;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      font-family: var(--hebrew);
    }
    .os-tab.active {
      color: var(--orange);
      border-bottom-color: var(--orange);
    }
    .os-tab:hover { color: var(--orange); }
    .os-panel { display: none; padding: 20px 0 0; }
    .os-panel.active { display: block; }

    /* Skill list */
    .skill-table {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin: 12px 0 24px;
    }
    .skill-item {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 10px 14px;
    }
    .skill-cmd {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--orange);
      font-weight: 600;
      display: block;
      margin-bottom: 2px;
    }
    .skill-desc {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.4;
    }
    @media (max-width: 580px) {
      .skill-table { grid-template-columns: 1fr; }
      .doc-content { padding: 24px 20px 40px; }
    }

    /* Download cards */
    .download-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
      margin: 16px 0 24px;
    }
    .download-card {
      background: var(--card-bg);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      padding: 20px 16px;
      text-align: center;
      transition: all 0.15s;
    }
    .download-card:hover { border-color: var(--orange); }
    .download-card .dl-icon { font-size: 28px; margin-bottom: 8px; }
    .download-card .dl-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
    .download-card .dl-desc { font-size: 12px; color: var(--faint); margin-bottom: 12px; line-height: 1.4; }
    .download-card .dl-btn {
      display: inline-block;
      background: var(--orange);
      color: #fff;
      font-family: var(--hebrew);
      font-size: 13px;
      font-weight: 700;
      padding: 8px 16px;
      border-radius: 6px;
      text-decoration: none;
      transition: background 0.15s;
    }
    .download-card .dl-btn:hover { background: var(--orange-h); color: #fff; }
    @media (max-width: 680px) {
      .download-grid { grid-template-columns: 1fr; }
    }

    /* ── CTA block ── */
    .cta-block {
      background: #1e1e2e;
      border-radius: 12px;
      padding: 48px 40px;
      text-align: center;
      margin: 48px 0 0;
    }
    .cta-block h2 { color: #fff; font-size: clamp(20px, 4vw, 32px); margin-bottom: 12px; }
    .cta-block p { color: #9090a0; font-size: 15px; margin-bottom: 28px; max-width: 480px; margin-left: auto; margin-right: auto; }
    .btn-cta {
      display: inline-block;
      background: var(--orange);
      color: #fff !important;
      font-family: var(--hebrew);
      font-size: 16px;
      font-weight: 700;
      padding: 16px 36px;
      border-radius: 8px;
      text-decoration: none;
      text-align: center;
      line-height: 1.4;
      box-shadow: 0 4px 16px rgba(200,100,60,0.3);
    }
    .btn-cta:hover { background: var(--orange-h); color: #fff !important; }
    .cta-note { font-size: 12px; color: #606070; margin-top: 12px; }

    /* ── Disclaimer ── */
    .disclaimer {
      background: #f4f3ee;
      border: 1px solid var(--border);
      border-right: 4px solid var(--faint);
      border-radius: 8px;
      padding: 16px 20px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
      margin: 24px 0;
    }
    .disclaimer strong { color: var(--text); }

    /* ── WhatsApp Community ── */
    .wa-block {
      background: #f4f3ee;
      border: 1.5px solid rgba(37,211,102,0.3);
      border-radius: 12px;
      padding: 32px;
      text-align: center;
      margin: 48px 0 0;
    }
    .wa-block h2 { font-size: 20px; font-weight: 800; margin-bottom: 8px; }
    .wa-block p { font-size: 14px; color: var(--muted); margin-bottom: 20px; }
    .btn-wa {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #25D366;
      color: #fff;
      font-family: var(--hebrew);
      font-size: 15px;
      font-weight: 700;
      padding: 12px 28px;
      border-radius: 8px;
      text-decoration: none;
      transition: all 0.15s;
    }
    .btn-wa:hover { background: #20bd5a; }
    .btn-wa svg { width: 18px; height: 18px; }
    .wa-note { font-size: 12px; color: var(--faint); margin-top: 10px; }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 32px 24px;
      border-top: 1px solid var(--border);
    }
    footer a { color: var(--muted); text-decoration: none; font-size: 13px; }
    footer a:hover { color: var(--orange); }
    .footer-links { display: flex; justify-content: center; gap: 24px; margin: 16px 0 8px; flex-wrap: wrap; }
    .footer-copy { font-size: 12px; color: var(--faint); }
  </style>
</head>
<body>
  <AnalyticsBody />

  <!-- Topbar -->
  <div class="topbar">
    <a href="https://focusai.co.il">&larr; חזרה לאתר Focus AI</a>
    <span class="topbar-lang"><a href="/claude-code-guide-en/">English version &rarr;</a></span>
  </div>

  <!-- Hero -->
  <div class="hero">
    <img src="https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,h_64/v1772353512/FOCUS_LOGO-02_hc0h1a.png"
         alt="Focus AI" height="64" style="display:block;margin:0 auto 16px;">
    <p class="hero-label">מדריך התקנה והפעלה</p>
    <h1>Claude Code<br><span class="headline-cursor">מאפס עד שימוש ראשון</span></h1>
    <p class="hero-sub">מדריך מלא בעברית: התקנת סביבת עבודה, Claude Code על Windows ו-Mac, הגדרת חשבון, התקנת סקילים וטיפים למתחילים.</p>
  </div>

  <!-- Download cards -->
  <div class="wrap" style="margin-bottom: 0;">
    <div style="
      background: var(--win-bg);
      border: 2px solid var(--orange);
      border-radius: 14px;
      padding: 28px 32px;
      margin-bottom: 32px;
    ">
      <p style="font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--orange); margin-bottom: 4px; text-align:center;">🎁 מתנה מ-Focus AI</p>
      <p style="font-size: 19px; font-weight: 800; color: var(--text); margin-bottom: 8px; line-height: 1.3; text-align:center;">50 סקילים מקצועיים, בחינם — בחרו את החבילה שלכם</p>
      <p style="font-size: 14px; color: var(--muted); line-height: 1.6; text-align:center; margin-bottom: 20px;">סקילים (Skills) הם הוראות מובנות שמרחיבות את היכולות של Claude Code. כל חבילה מותאמת לתפקיד שלכם.</p>
      <div class="download-grid">
        <div class="download-card">
          <div class="dl-icon">💻</div>
          <div class="dl-title">למפתחים</div>
          <div class="dl-desc">Code review, debugging, testing, git, architecture, security</div>
          <a href="https://res.cloudinary.com/dfudxxzlj/raw/upload/focusai/downloads/claude-code-skills-bundle.zip" download class="dl-btn">⬇ הורד ZIP</a>
        </div>
