  <script>
    function switchTab(btn, group, os) {
      // Deactivate all tabs in this group
      document.querySelectorAll('.os-tabs[data-group="' + group + '"] .os-tab').forEach(function(t) {
        t.classList.remove('active');
      });
      btn.classList.add('active');
      // Show the right panel
      document.querySelectorAll('.os-panel[data-group="' + group + '"]').forEach(function(p) {
        p.classList.remove('active');
      });
      var target = document.querySelector('.os-panel[data-group="' + group + '"][data-os="' + os + '"]');
      if (target) target.classList.add('active');
    }
  </script>

