    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            zoom: 1 !important;
        }

        :root {
            --primary: #8b5cf6;
            --primary-dark: #7c3aed;
            --secondary: #06b6d4;
            --accent: #f59e0b;
            --success: #10b981;
            --live-red: #ef4444;
            --dark: #0f0f1a;
            --darker: #080810;
            --card-bg: rgba(255, 255, 255, 0.03);
            --card-border: rgba(255, 255, 255, 0.08);
            --text: #ffffff;
            --text-muted: rgba(255, 255, 255, 0.6);
            --glow-primary: rgba(139, 92, 246, 0.4);
            --glow-secondary: rgba(6, 182, 212, 0.4);
        }

        body {
            font-family: 'Heebo', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--darker);
            min-height: 100vh;
            color: var(--text);
            overflow-x: hidden;
        }

        .back-home {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: rgba(255,255,255,0.45);
            font-size: 0.85rem;
            text-decoration: none;
            padding: 12px 0 8px;
            transition: color 0.3s;
        }
        .back-home:hover {
            color: var(--primary);
        }
        .back-home i {
            font-size: 0.75rem;
        }

        /* Animated Background */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }

        .bg-animation::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background:
                radial-gradient(circle at 20% 80%, var(--glow-primary) 0%, transparent 40%),
                radial-gradient(circle at 80% 20%, var(--glow-secondary) 0%, transparent 40%),
                radial-gradient(circle at 40% 40%, rgba(239, 68, 68, 0.1) 0%, transparent 30%);
            animation: bgMove 20s ease-in-out infinite;
        }

        @keyframes bgMove {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(2%, 2%) rotate(1deg); }
            66% { transform: translate(-1%, 1%) rotate(-1deg); }
        }

        /* Floating particles */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: var(--primary);
            border-radius: 50%;
            opacity: 0.3;
            animation: float 15s infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 0.3; }
            90% { opacity: 0.3; }
            100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
        }

        .container {
            max-width: 700px;
            margin: 0 auto;
            padding: 15px;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* Header */
        header {
            text-align: center;
            padding: 28px 12px 20px;
            position: relative;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .logo {
            height: 48px;
            width: auto;
            filter: drop-shadow(0 0 20px rgba(139, 92, 246, 0.3));
            margin-bottom: 20px;
            transition: all 0.3s ease;
            display: block;
        }

        .logo:hover {
            transform: scale(1.05);
            filter: drop-shadow(0 0 30px rgba(139, 92, 246, 0.5));
        }

        /* LIVE Badge */
        .live-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: linear-gradient(135deg, var(--live-red), #dc2626);
            padding: 8px 20px;
            border-radius: 30px;
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 16px;
            box-shadow: 0 4px 20px rgba(239, 68, 68, 0.4);
            animation: livePulse 2s ease-in-out infinite;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .live-badge .live-dot {
            width: 10px;
            height: 10px;
            background: white;
            border-radius: 50%;
            animation: liveDot 1.5s ease-in-out infinite;
        }

        @keyframes livePulse {
            0%, 100% { box-shadow: 0 4px 20px rgba(239, 68, 68, 0.4); }
            50% { box-shadow: 0 4px 35px rgba(239, 68, 68, 0.6), 0 0 60px rgba(239, 68, 68, 0.2); }
        }

        @keyframes liveDot {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        /* Event Date Badge */
        .event-date-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: center;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(6, 182, 212, 0.1));
            border: 1px solid rgba(139, 92, 246, 0.3);
            padding: 10px 18px;
            border-radius: 16px;
            margin-bottom: 22px;
            font-size: 0.9rem;
            font-weight: 600;
        }

        .event-date-badge i {
            color: var(--secondary);
            font-size: 1.1rem;
        }

        .event-date-badge .separator {
            width: 1px;
            height: 20px;
            background: var(--card-border);
        }

        header h1 {
            font-size: 1.9rem;
            font-weight: 800;
            background: linear-gradient(135deg, #fff 0%, var(--primary) 50%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            color: transparent;
            margin-bottom: 12px;
            line-height: 1.2;
        }

        .n8n-highlight {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 16px;
        }

        .n8n-highlight img {
            height: 22px;
            width: auto;
        }

        .n8n-highlight span {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-muted);
        }

        header .subtitle {
            font-size: 0.95rem;
            color: var(--text-muted);
            font-weight: 400;
            line-height: 1.6;
            max-width: 500px;
            margin: 0 auto;
        }

        header .subtitle strong {
            color: var(--text);
        }

        /* No Recording Badge */
        .no-recording-badge {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            margin-top: 14px;
            position: relative;
            animation: noRecPulse 3s ease-in-out infinite;
        }

        .no-recording-badge i {
            font-size: 1.6rem;
            color: var(--live-red);
            filter: drop-shadow(0 0 8px rgba(239, 68, 68, 0.5));
            animation: noRecShake 4s ease-in-out infinite;
        }

        .no-rec-text {
            font-size: 2rem;
            font-weight: 900;
            color: transparent;
            background: linear-gradient(135deg, var(--live-red), #ff6b6b, var(--live-red));
            background-size: 200% auto;
            -webkit-background-clip: text;
            background-clip: text;
            animation: noRecShimmer 3s linear infinite;
            letter-spacing: 1px;
        }

        .no-rec-line {
            display: block;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--live-red), #ff6b6b, var(--live-red), transparent);
            border-radius: 2px;
            animation: noRecLineGrow 2s ease-out 0.5s forwards;
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.4);
        }

        @keyframes noRecShimmer {
            0% { background-position: 200% center; }
            100% { background-position: -200% center; }
        }

        @keyframes noRecLineGrow {
            0% { width: 0; }
            100% { width: 100%; }
        }

        @keyframes noRecShake {
            0%, 100% { transform: rotate(0deg); }
            10% { transform: rotate(-5deg); }
            20% { transform: rotate(5deg); }
            30% { transform: rotate(0deg); }
        }

        @keyframes noRecPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.03); }
        }

        /* Hero Character */
        .hero-character {
            margin: 16px 0 20px;
            width: 100%;
            max-width: 480px;
        }

        .hero-character img {
            width: 100%;
            height: auto;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 12px 40px rgba(139, 92, 246, 0.2);
        }

        /* Countdown Timer */
        .countdown-section {
            width: 100%;
            margin-bottom: 25px;
        }

        .countdown-label {
            text-align: center;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .countdown-timer {
            display: flex;
            justify-content: center;
            gap: 12px;
            direction: ltr;
        }

        .countdown-unit {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--card-border);
            border-radius: 14px;
            padding: 10px 12px;
            min-width: 60px;
            text-align: center;
        }

        .countdown-unit .number {
            font-size: 1.4rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: block;
            line-height: 1;
        }

        .countdown-unit .label {
            font-size: 0.7rem;
            color: var(--text-muted);
            margin-top: 4px;
            display: block;
        }

        .countdown-expired {
            text-align: center;
            padding: 20px;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--live-red);
        }

        /* Main Card */
        .main-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 22px 16px;
            margin-bottom: 25px;
            border: 1px solid var(--card-border);
            box-shadow:
                0 25px 50px -12px rgba(0, 0, 0, 0.5),
                inset 0 1px 0 rgba(255, 255, 255, 0.05);
            position: relative;
            overflow: hidden;
            width: 100%;
        }

        .main-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--live-red), var(--primary), var(--secondary));
        }

        /* Section title */
        .section-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-align: center;
        }

        .section-title i {
            color: var(--primary);
            font-size: 1.2rem;
        }

        .section-title::before,
        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--card-border), transparent);
            max-width: 80px;
        }

        /* Speakers Section */
        .speakers-section {
            margin-bottom: 30px;
        }

        .speakers-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .speaker-card {
            background: rgba(139, 92, 246, 0.05);
            border: 1px solid rgba(139, 92, 246, 0.15);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .speaker-card:hover {
            background: rgba(139, 92, 246, 0.1);
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(139, 92, 246, 0.15);
        }

        .speaker-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 3rem;
            font-weight: 800;
            color: white;
            box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
            overflow: hidden;
        }

        .speaker-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Hosts vs Presenters sub-labels */
        .speakers-sublabel {
            text-align: center;
            font-size: 0.78rem;
            color: var(--text-muted);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .speaker-name {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 4px;
        }

        .speaker-role {
            font-size: 0.8rem;
            color: var(--secondary);
            font-weight: 600;
            margin-bottom: 6px;
        }

        .speaker-business {
            font-size: 0.78rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .speaker-business i {
            font-size: 0.7rem;
            color: var(--primary);
        }

        .speaker-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin-top: 10px;
            padding: 4px 12px;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(6, 182, 212, 0.1));
            border: 1px solid rgba(139, 92, 246, 0.25);
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--primary);
        }

        .speaker-badge i {
            font-size: 0.65rem;
        }

        /* What you'll see */
        /* Customer Journey Narrative */
        .journey-section {
            margin-bottom: 36px;
            padding: 0 4px;
        }

        .journey-opener {
            font-size: 1.6rem;
            font-weight: 300;
            color: rgba(255, 255, 255, 0.85);
            line-height: 1.7;
            margin-bottom: 24px;
            font-style: italic;
        }

        .journey-opener strong {
            font-weight: 700;
            color: var(--text);
            font-style: normal;
        }

        .journey-highlight {
            display: block;
            font-size: 1.3rem;
            font-weight: 800;
            color: transparent;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            background-clip: text;
            margin: 28px 0 16px;
            line-height: 1.5;
        }

        .journey-text {
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.9;
            margin-bottom: 18px;
        }

        .journey-text strong {
            color: var(--text);
            font-weight: 600;
        }

        .journey-text em {
            color: var(--primary);
            font-style: normal;
            font-weight: 500;
        }

        .journey-pullquote {
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--text);
            padding: 16px 20px;
            border-right: 3px solid var(--primary);
            background: rgba(139, 92, 246, 0.06);
            border-radius: 0 12px 12px 0;
            margin: 24px 0;
            line-height: 1.7;
        }

        .journey-divider {
            width: 60px;
            height: 2px;
            background: linear-gradient(90deg, var(--primary), transparent);
            margin: 28px 0;
            border: none;
        }

        .journey-chapter {
            font-size: 1.875rem;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--secondary);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .journey-chapter::before {
            content: '';
            width: 20px;
            height: 20px;
            background: var(--secondary);
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }

        .journey-big {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--text);
            line-height: 1.4;
            margin-bottom: 14px;
        }

        .journey-steps {
            display: flex;
            flex-direction: column;
            gap: 14px;
            margin: 20px 0;
        }

        .journey-step {
            display: flex;
            align-items: baseline;
            gap: 10px;
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.75);
            line-height: 1.7;
        }

        .journey-step .step-marker {
            font-size: 1.4rem;
            line-height: 1;
        }

        .journey-step strong {
            color: var(--text);
        }


        /* Exclusive Benefits */
        .benefits-section {
            margin-bottom: 30px;
            padding: 20px;
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.08), rgba(139, 92, 246, 0.05));
            border-radius: 16px;
            border: 1px solid rgba(245, 158, 11, 0.25);
        }

        .benefits-header {
            text-align: center;
            margin-bottom: 16px;
        }

        .benefits-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, var(--accent), #d97706);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            color: #0f0f1a;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .benefits-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text);
        }

        .benefits-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .benefit-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            border: 1px solid var(--card-border);
        }

        .benefit-item i {
            font-size: 1.2rem;
            color: var(--accent);
            flex-shrink: 0;
        }

        .benefit-item span {
            font-size: 0.9rem;
            color: var(--text);
            font-weight: 500;
        }

        /* Target Audience */
        .audience-note {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px 18px;
            background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(139, 92, 246, 0.05));
            border-radius: 12px;
            margin-bottom: 30px;
            border: 1px solid rgba(6, 182, 212, 0.2);
        }

        .audience-note i {
            font-size: 1.4rem;
            color: var(--secondary);
            flex-shrink: 0;
        }

        .audience-note p {
            font-size: 0.9rem;
            color: var(--text);
            line-height: 1.5;
        }

        .audience-note strong {
            color: var(--secondary);
        }

        /* Form Section */
        .form-section {
            padding-top: 25px;
            border-top: 1px solid var(--card-border);
        }

        .form-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .form-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text);
            background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .form-subtitle {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .form-row {
            display: flex;
            gap: 12px;
        }

        .form-row .form-group {
            flex: 1;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .form-group label i {
            color: var(--primary);
            font-size: 0.9rem;
        }

        .required::after {
            content: " *";
            color: var(--accent);
        }

        input[type="text"],
        input[type="email"],
        input[type="tel"] {
            width: 100%;
            padding: 14px 18px;
            background: rgba(255, 255, 255, 0.03);
            border: 2px solid var(--card-border);
            border-radius: 12px;
            font-size: 1rem;
            font-family: inherit;
            color: var(--text);
            transition: all 0.3s ease;
        }

        input::placeholder {
            color: var(--text-muted);
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            background: rgba(139, 92, 246, 0.05);
            box-shadow: 0 0 0 4px var(--glow-primary);
        }

        /* Prevent autofill from turning inputs white */
        input:-webkit-autofill,
        input:-webkit-autofill:hover,
        input:-webkit-autofill:focus,
        input:-webkit-autofill:active {
            -webkit-box-shadow: 0 0 0 1000px rgba(15, 15, 26, 0.97) inset !important;
            -webkit-text-fill-color: var(--text) !important;
            background-color: rgba(255, 255, 255, 0.03) !important;
            border-color: var(--card-border) !important;
            transition: background-color 5000s ease-in-out 0s;
        }

        input:-webkit-autofill:focus {
            -webkit-box-shadow: 0 0 0 1000px rgba(139, 92, 246, 0.08) inset !important;
            border-color: var(--primary) !important;
        }

        /* Privacy Section */
        .privacy-section {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--card-border);
        }

        .privacy-notice {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 15px;
            line-height: 1.6;
            padding: 12px 15px;
            background: rgba(245, 158, 11, 0.05);
            border-radius: 10px;
            border-right: 3px solid var(--accent);
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .privacy-notice i {
            color: var(--accent);
            margin-top: 2px;
        }

        .checkbox-group {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 12px;
            cursor: pointer;
        }

        .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            margin-top: 2px;
            accent-color: var(--primary);
            cursor: pointer;
        }

        .checkbox-label {
            font-size: 0.85rem;
            color: var(--text-muted);
            line-height: 1.5;
        }

        .checkbox-label a {
            color: var(--primary);
            text-decoration: underline;
        }

        .checkbox-label a:hover {
            color: var(--secondary);
        }

        /* Submit Button */
        .btn-submit {
            width: 100%;
            padding: 20px 30px;
            margin-top: 20px;
            background: linear-gradient(135deg, var(--live-red) 0%, #dc2626 50%, #b91c1c 100%);
            color: white;
            border: none;
            border-radius: 16px;
            font-size: 1.2rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: inherit;
            box-shadow:
                0 4px 20px rgba(239, 68, 68, 0.4),
                0 0 0 0 rgba(239, 68, 68, 0.4),
                inset 0 1px 0 rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            position: relative;
            overflow: hidden;
        }

        .btn-submit::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .btn-submit:hover::before {
            left: 100%;
        }

        .btn-submit:hover {
            transform: translateY(-4px);
            box-shadow:
                0 12px 35px rgba(239, 68, 68, 0.5),
                0 0 0 4px rgba(239, 68, 68, 0.15),
                inset 0 1px 0 rgba(255, 255, 255, 0.2);
        }

        .btn-submit:active {
            transform: translateY(-2px);
        }

        .btn-submit:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
        }

        .btn-submit .btn-text {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-submit i {
            font-size: 1.3rem;
            animation: pulse-icon 2s ease-in-out infinite;
        }

        @keyframes pulse-icon {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .form-wa-note {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 14px;
            padding: 10px 16px;
            background: rgba(34, 197, 94, 0.06);
            border: 1px solid rgba(34, 197, 94, 0.2);
            border-radius: 10px;
            font-size: 0.82rem;
            color: #9590b0;
            line-height: 1.5;
        }
        .form-wa-note i {
            color: #22c55e;
            font-size: 1rem;
            flex-shrink: 0;
        }
        .form-wa-note strong {
            color: #4ade80;
            font-weight: 600;
        }

        /* WhatsApp Community Invite (after first form) */
        .wa-community-invite {
            display: flex;
            align-items: center;
            gap: 16px;
            margin: 24px 0 32px;
            padding: 16px 20px;
            background: rgba(37, 211, 102, 0.06);
            border: 1px solid rgba(37, 211, 102, 0.15);
            border-radius: 16px;
            direction: rtl;
        }
        .wa-invite-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(37, 211, 102, 0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 1.3rem;
            color: #25d366;
        }
        .wa-invite-content {
            flex: 1;
            min-width: 0;
        }
        .wa-invite-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: #e8e4f0;
            margin-bottom: 2px;
        }
        .wa-invite-text {
            font-size: 0.8rem;
            color: #9590b0;
            line-height: 1.4;
        }
        .wa-invite-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 18px;
            background: #25d366;
            color: #fff;
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 10px;
            text-decoration: none;
            white-space: nowrap;
            transition: background 0.2s, transform 0.15s;
            flex-shrink: 0;
        }
        .wa-invite-btn:hover {
            background: #1fb855;
            transform: translateY(-1px);
        }
        .wa-invite-btn i {
            font-size: 0.7rem;
        }
        @media (max-width: 600px) {
            .wa-community-invite {
                flex-direction: column;
                text-align: center;
                gap: 12px;
                padding: 16px;
            }
            .wa-invite-btn {
                width: 100%;
                justify-content: center;
            }
        }

        /* Community Section */
        .community-section {
            margin-top: 25px;
            padding-top: 25px;
            border-top: 1px solid var(--card-border);
            text-align: center;
        }

        .community-section .section-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .community-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            padding: 14px 28px;
            background: linear-gradient(135deg, rgba(37, 211, 102, 0.15), rgba(37, 211, 102, 0.08));
            border: 1px solid rgba(37, 211, 102, 0.4);
            border-radius: 14px;
            color: var(--text);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .community-btn:hover {
            background: linear-gradient(135deg, rgba(37, 211, 102, 0.25), rgba(37, 211, 102, 0.15));
            border-color: rgba(37, 211, 102, 0.6);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(37, 211, 102, 0.2);
        }

        .community-btn i {
            font-size: 1.3rem;
            color: #25d366;
        }

        .community-btn span {
            color: #25d366;
            font-weight: 700;
        }

        /* Footer/Disclaimer */
        .disclaimer {
            margin-top: 25px;
            padding: 20px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 16px;
            border: 1px solid var(--card-border);
            width: 100%;
        }

        .disclaimer-title {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .disclaimer-title i {
            color: var(--accent);
        }

        .disclaimer-text {
            font-size: 0.75rem;
            color: var(--text-muted);
            line-height: 1.7;
            opacity: 0.8;
        }

        .disclaimer-text a {
            color: var(--primary);
            text-decoration: underline;
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin: 20px 0;
        }

        .social-link {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            transition: all 0.3s;
            text-decoration: none;
        }

        .social-link:hover {
            background: rgba(139, 92, 246, 0.2);
            color: #fff;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid var(--card-border);
        }

        .footer-links a {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.3s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .footer-links a:hover {
            color: var(--primary);
        }

        .footer-links a i {
            font-size: 0.7rem;
        }

        /* Success Message */
        .success-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(8, 8, 16, 0.95);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .success-overlay.show {
            display: flex;
        }

        .success-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 40px 30px;
            max-width: 450px;
            width: 100%;
            text-align: center;
            border: 1px solid var(--card-border);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            animation: successIn 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        @keyframes successIn {
            from {
                opacity: 0;
                transform: scale(0.9) translateY(20px);
            }
            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .success-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--success), #059669);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            box-shadow: 0 10px 30px rgba(16, 185, 129, 0.4);
        }

        .success-icon i {
            font-size: 2.2rem;
            color: white;
        }

        .success-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 15px;
            color: var(--text);
        }

        .success-message {
            font-size: 1rem;
            color: var(--text-muted);
            line-height: 1.7;
            margin-bottom: 25px;
        }

        .success-details {
            background: rgba(139, 92, 246, 0.1);
            padding: 20px;
            border-radius: 16px;
            border: 1px solid rgba(139, 92, 246, 0.3);
            margin-bottom: 20px;
        }

        .success-details .detail-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 6px 0;
            font-size: 0.95rem;
            color: var(--text);
        }

        .success-details .detail-row i {
            color: var(--primary);
            font-size: 0.9rem;
        }

        .success-note {
            font-size: 0.85rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .success-note i {
            color: var(--secondary);
        }

        /* ===== Story Hook Section ===== */
        .story-hook {
            width: 100%;
            margin-bottom: 20px;
            padding: 24px 20px;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            border: 1px solid var(--card-border);
            text-align: center;
            position: relative;
            overflow: visible;
        }

        .story-hook::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), var(--secondary), transparent);
            z-index: 1;
        }

        .story-hook .hook-image-wrap {
            position: relative;
            margin: 18px auto 28px;
            max-width: 340px;
        }

        .story-hook .hook-image {
            padding: 3px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(139, 92, 246, 0.25);
            transform: rotate(-2deg);
            transition: transform 0.3s ease;
        }

        .story-hook .hook-image:hover {
            transform: rotate(0deg) scale(1.02);
        }

        .story-hook .hook-image img {
            width: 100%;
            border-radius: 10px;
            display: block;
        }

        .hook-label {
            position: absolute;
            top: -20px;
            right: -10px;
            transform: rotate(6deg);
        }

        .hook-label-text {
            font-size: 2rem;
            font-weight: 800;
            font-style: normal;
            color: var(--live-red);
            filter: drop-shadow(0 2px 8px rgba(239, 68, 68, 0.5));
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        .story-hook .hook-question {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 14px;
            line-height: 1.4;
        }

        .story-hook .hook-answer {
            font-size: 0.92rem;
            color: var(--text-muted);
            line-height: 1.7;
            max-width: 520px;
            margin: 0 auto 18px;
        }

        .story-hook .hook-answer strong {
            color: var(--text);
        }

        .story-hook .hook-answer em {
            color: var(--secondary);
            font-style: normal;
            font-weight: 600;
        }

        .story-stats {
            display: flex;
            justify-content: center;
            gap: 16px;
        }

        .story-stat {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 10px 16px;
            background: rgba(139, 92, 246, 0.06);
            border-radius: 12px;
            border: 1px solid rgba(139, 92, 246, 0.12);
            min-width: 80px;
        }

        .story-stat .stat-number {
            font-size: 1.3rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .story-stat .stat-label {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-align: center;
        }

        /* ===== Projects Showcase Section ===== */
        /* (project-card + agenda styles replaced by .journey-section) */

        /* ===== MOBILE-FIRST Responsive ===== */
        /* Base styles above = mobile. Media queries scale UP. */

        /* Tablet (min-width: 480px) */
        @media (min-width: 480px) {
            .container {
                padding: 20px;
            }

            header {
                padding: 36px 20px 26px;
            }

            header h1 {
                font-size: 2.4rem;
            }

            .speakers-grid {
                grid-template-columns: 1fr 1fr;
            }

            .main-card {
                padding: 30px 24px;
            }

            .story-stats {
                flex-wrap: nowrap;
            }
        }

        /* Small Desktop (min-width: 768px) */
        @media (min-width: 768px) {
            .container {
                max-width: 900px;
                padding: 30px;
            }

            header h1 {
                font-size: 2.8rem;
            }

            header .subtitle {
                font-size: 1.1rem;
                max-width: 600px;
            }

            .logo {
                height: 55px;
                margin-bottom: 25px;
            }

            .hero-character {
                max-width: 520px;
            }

            .main-card {
                padding: 40px;
                border-radius: 24px;
            }

            .countdown-unit {
                min-width: 80px;
                padding: 16px 20px;
            }

            .countdown-unit .number {
                font-size: 2rem;
            }

            .event-date-badge {
                flex-wrap: nowrap;
                font-size: 1rem;
                gap: 12px;
                padding: 12px 24px;
            }

            .n8n-highlight img {
                height: 28px;
            }

            .n8n-highlight span {
                font-size: 1.1rem;
            }

            .story-hook {
                padding: 32px 40px;
            }

            .story-hook .hook-image-wrap {
                max-width: 420px;
            }

            .story-hook .hook-question {
                font-size: 1.4rem;
            }

            .story-hook .hook-answer {
                font-size: 1rem;
            }

            .section-title {
                font-size: 1.3rem;
            }

            .speaker-avatar {
                width: 180px;
                height: 180px;
            }

            .journey-opener {
                font-size: 1.9rem;
            }

            .journey-highlight {
                font-size: 1.5rem;
            }

            .journey-big {
                font-size: 2.1rem;
            }

            .journey-text {
                font-size: 1.05rem;
            }

            .journey-pullquote {
                font-size: 1.25rem;
            }

            .footer-links {
                flex-wrap: nowrap;
                gap: 20px;
            }
        }

        /* Large Desktop (min-width: 1024px) */
        @media (min-width: 1024px) {
            .container {
                max-width: 1000px;
                padding: 40px;
            }

            header h1 {
                font-size: 3.2rem;
            }

            header .subtitle {
                font-size: 1.15rem;
            }

            .hero-character {
                max-width: 560px;
            }

            .main-card {
                padding: 50px;
            }

            .countdown-unit {
                min-width: 90px;
                padding: 18px 24px;
            }

            .countdown-unit .number {
                font-size: 2.2rem;
            }

            .story-hook {
                padding: 40px 50px;
            }

            .story-hook .hook-image-wrap {
                max-width: 460px;
            }

            .hook-label-text {
                font-size: 2.6rem;
            }

            .hook-label {
                right: -24px;
                top: -24px;
            }

            .story-hook .hook-question {
                font-size: 1.5rem;
            }

            .speaker-avatar {
                width: 200px;
                height: 200px;
            }

            .benefits-section {
                padding: 28px;
            }

            .journey-opener {
                font-size: 2.2rem;
            }

            .journey-highlight {
                font-size: 1.7rem;
            }

            .journey-big {
                font-size: 2.4rem;
            }

            .journey-text {
                font-size: 1.1rem;
            }

            .journey-pullquote {
                font-size: 1.35rem;
                padding: 22px 28px;
            }

            .journey-step {
                font-size: 1.1rem;
            }


            .form-title {
                font-size: 1.4rem;
            }
        }

        /* Loading state */
        .btn-submit.loading {
            pointer-events: none;
        }

        .btn-submit.loading .btn-text {
            display: none;
        }

        .btn-submit .spinner {
            display: none;
        }

        .btn-submit.loading .spinner {
            display: inline-block;
            width: 22px;
            height: 22px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Validation error styles */
        input.error, select.error, textarea.error {
            border-color: #ef4444 !important;
            box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.2);
        }
        input[type="checkbox"].error {
            outline: 2px solid #ef4444;
