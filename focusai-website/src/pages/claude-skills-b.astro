---
/**
 * Claude Code Skills Bundle — English Landing Page
 * Standalone page (no site header/footer)
 * Target: International market ($15 paid)
 * Route: /claude-skills/
 */
import Analytics from '../components/Analytics.astro';
import AnalyticsBody from '../components/AnalyticsBody.astro';
---
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>50 Claude Code Skills Bundle — Level Up Your AI Workflow</title>
  <meta name="description" content="50 professional Claude Code skills built on official Anthropic best practices. Code review, security, testing, architecture, debugging — installed in 60 seconds.">
  <meta name="robots" content="noindex">

  <!-- OG -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://focusai.co.il/claude-skills/">
  <meta property="og:title" content="50 Claude Code Skills Bundle">
  <meta property="og:description" content="50 professional skills for Claude Code — code review, security audits, debugging, architecture, testing and more. Install in 60 seconds.">
  <meta property="og:image" content="https://res.cloudinary.com/dfudxxzlj/image/upload/q_auto,f_auto,w_1200/v1765302030/focusai-og-image.png">
  <meta property="og:site_name" content="Focus AI">

  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="icon" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <meta name="theme-color" content="#0a0a0f">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

  <Analytics slot="head" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --bg2: #0f0f1a;
      --bg3: #141424;
      --purple: #a855f7;
      --purple-dim: #7c3aed;
      --purple-glow: rgba(168,85,247,0.15);
      --border: rgba(255,255,255,0.08);
      --border-purple: rgba(168,85,247,0.3);
      --text: #e8e8f0;
      --text-dim: #9090b0;
      --text-muted: #606080;
      --glass: rgba(255,255,255,0.03);
      --glass-hover: rgba(255,255,255,0.06);
      --radius: 16px;
      --radius-sm: 10px;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── Noise texture overlay ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.4;
    }

    /* ── Layout ── */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
    .container-narrow { max-width: 760px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

    /* ── Glass card ── */
    .glass {
      background: var(--glass);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .glass-purple {
      background: rgba(168,85,247,0.05);
      border-color: var(--border-purple);
    }

    /* ── Tags / badges ── */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 16px;
      background: var(--glass);
      border: 1px solid var(--border-purple);
      border-radius: 30px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--purple);
    }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--purple); animation: pulse 2s infinite; flex-shrink: 0; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.85)} }

    /* ── Gradient text ── */
    .grad { background: linear-gradient(135deg, #e8d5ff 0%, #a855f7 50%, #7c3aed 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    /* ── Buttons ── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 36px;
      background: linear-gradient(135deg, #7c3aed, #a855f7);
      color: #fff;
      font-size: 16px;
      font-weight: 700;
      border-radius: 12px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      box-shadow: 0 0 30px rgba(168,85,247,0.35);
      transition: all 0.2s;
      letter-spacing: 0.2px;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 45px rgba(168,85,247,0.5); }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 28px;
      background: var(--glass);
      border: 1px solid var(--border);
      color: var(--text-dim);
      font-size: 14px;
      font-weight: 500;
      border-radius: 10px;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-secondary:hover { border-color: var(--border-purple); color: var(--text); }

    /* ── Section spacing ── */
    section { padding: 80px 0; }
    .section-label { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--purple); margin-bottom: 16px; }
    .section-title { font-size: clamp(28px, 4vw, 42px); font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
    .section-sub { font-size: 17px; color: var(--text-dim); line-height: 1.7; max-width: 600px; }

    /* ── Mono font ── */
    .mono { font-family: 'JetBrains Mono', 'Fira Code', monospace; }

    /* ─────────────────────── HERO ─────────────────────── */
    #hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 120px 0 80px;
      position: relative;
      overflow: hidden;
    }
    #hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 800px;
      background: radial-gradient(ellipse, rgba(124,58,237,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-inner { text-align: center; }
    .hero-eyebrow { margin-bottom: 28px; }
    .hero-h1 {
      font-size: clamp(40px, 6vw, 72px);
      font-weight: 900;
      line-height: 1.08;
      letter-spacing: -1.5px;
      margin-bottom: 24px;
    }
    .hero-sub {
      font-size: clamp(17px, 2vw, 20px);
      color: var(--text-dim);
      line-height: 1.7;
      max-width: 600px;
      margin: 0 auto 40px;
    }
    .hero-cta { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; }
    .hero-proof {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 32px;
      margin-top: 56px;
      flex-wrap: wrap;
    }
    .proof-item { text-align: center; }
    .proof-num { font-size: 32px; font-weight: 800; color: var(--purple); line-height: 1; }
    .proof-label { font-size: 12px; color: var(--text-muted); margin-top: 4px; letter-spacing: 0.5px; }
    .proof-sep { width: 1px; height: 40px; background: var(--border); }

    /* Terminal preview */
    .terminal {
      max-width: 520px;
      margin: 60px auto 0;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
      background: #0d0d18;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(168,85,247,0.1);
    }
    .terminal-header {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      background: rgba(255,255,255,0.03);
      border-bottom: 1px solid var(--border);
    }
    .t-dot { width: 12px; height: 12px; border-radius: 50%; }
    .t-dot.r { background: #ff5f57; }
    .t-dot.y { background: #ffbd2e; }
    .t-dot.g { background: #28c840; }
    .terminal-title { font-size: 12px; color: var(--text-muted); flex: 1; text-align: center; font-family: inherit; }
    .terminal-body { padding: 20px 20px 24px; }
    .t-line { font-family: 'JetBrains Mono', monospace; font-size: 13px; line-height: 2; display: flex; gap: 10px; }
    .t-prompt { color: var(--purple); }
    .t-cmd { color: #e8e8f0; }
    .t-out { color: #606080; }
    .t-green { color: #4ade80; }
    .t-purple { color: #c084fc; }

    /* ── Marquee strip ── */
    .marquee-wrap {
      overflow: hidden;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: rgba(168,85,247,0.04);
      padding: 14px 0;
    }
    .marquee-track { display: flex; width: max-content; animation: marquee 30s linear infinite; gap: 0; }
    .marquee-track:hover { animation-play-state: paused; }
    .marquee-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 0 28px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--text-muted);
      white-space: nowrap;
      border-right: 1px solid var(--border);
    }
    .marquee-item span { width: 4px; height: 4px; border-radius: 50%; background: var(--purple); display: block; }
    @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* ─────────────────────── CATEGORIES ─────────────────────── */
    .cat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 16px;
      margin-top: 48px;
    }
    .cat-card {
      padding: 24px;
      border-radius: var(--radius);
      background: var(--glass);
      border: 1px solid var(--border);
      transition: all 0.25s;
      cursor: default;
    }
    .cat-card:hover { background: var(--glass-hover); border-color: var(--border-purple); transform: translateY(-2px); }
    .cat-icon { font-size: 28px; margin-bottom: 14px; }
    .cat-name { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
    .cat-count { font-size: 12px; color: var(--purple); font-weight: 600; margin-bottom: 12px; }
    .cat-skills { display: flex; flex-wrap: wrap; gap: 6px; }
    .skill-chip {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 6px;
      background: rgba(168,85,247,0.08);
      border: 1px solid rgba(168,85,247,0.15);
      color: var(--text-dim);
    }

    /* ─────────────────────── HOW IT WORKS ─────────────────────── */
    .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
    .step {
      padding: 32px 28px;
      border-radius: var(--radius);
      background: var(--glass);
      border: 1px solid var(--border);
      text-align: center;
      position: relative;
    }
    .step::after {
      content: '';
      position: absolute;
      top: 50%;
      right: -12px;
      transform: translateY(-50%);
      width: 24px;
      height: 1px;
      background: linear-gradient(90deg, var(--border-purple), transparent);
    }
    .step:last-child::after { display: none; }
    .step-num {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--purple-dim), var(--purple));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: 800;
      margin: 0 auto 16px;
    }
    .step-title { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .step-desc { font-size: 13px; color: var(--text-dim); line-height: 1.6; }
    .step-code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--purple);
      background: rgba(168,85,247,0.08);
      border: 1px solid rgba(168,85,247,0.15);
      border-radius: 6px;
      padding: 8px 12px;
      margin-top: 14px;
      text-align: left;
    }

    /* ─────────────────────── PRICING ─────────────────────── */
    #pricing { text-align: center; }
    .price-card {
      max-width: 480px;
      margin: 48px auto 0;
      padding: 48px;
      border-radius: 20px;
      background: rgba(168,85,247,0.05);
      border: 1px solid var(--border-purple);
      box-shadow: 0 0 60px rgba(168,85,247,0.1), inset 0 0 60px rgba(168,85,247,0.03);
      position: relative;
      overflow: hidden;
    }
    .price-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #7c3aed, #a855f7, #7c3aed);
    }
    .price-amount { font-size: 72px; font-weight: 900; color: var(--purple); line-height: 1; margin: 24px 0 8px; }
    .price-amount sup { font-size: 32px; vertical-align: top; margin-top: 12px; }
    .price-original { font-size: 18px; color: var(--text-muted); text-decoration: line-through; margin-bottom: 4px; }
    .price-label { font-size: 13px; color: var(--text-dim); margin-bottom: 32px; }
    .price-includes { text-align: left; margin: 32px 0; display: flex; flex-direction: column; gap: 12px; }
    .price-item { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; }
    .price-item svg { width: 18px; height: 18px; color: #4ade80; flex-shrink: 0; margin-top: 1px; }
    .price-item-text { color: var(--text-dim); }
    .price-item-text strong { color: var(--text); }
    .guarantee { margin-top: 24px; font-size: 12px; color: var(--text-muted); display: flex; align-items: center; justify-content: center; gap: 6px; }

    /* ─────────────────────── FAQ ─────────────────────── */
    .faq-list { margin-top: 48px; display: flex; flex-direction: column; gap: 12px; }
    .faq-item {
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      background: var(--glass);
      overflow: hidden;
    }
    .faq-q {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 24px;
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
      gap: 16px;
      font-family: inherit;
    }
    .faq-q:hover { color: var(--purple); }
    .faq-icon { flex-shrink: 0; width: 20px; height: 20px; color: var(--purple); transition: transform 0.2s; }
    .faq-item.open .faq-icon { transform: rotate(45deg); }
    .faq-a {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.2s;
    }
    .faq-item.open .faq-a { max-height: 300px; }
    .faq-a-inner { padding: 0 24px 20px; font-size: 14px; color: var(--text-dim); line-height: 1.7; }
    .faq-a-inner code { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--purple); background: rgba(168,85,247,0.1); padding: 2px 6px; border-radius: 4px; }

    /* ─────────────────────── FOOTER ─────────────────────── */
    footer {
      padding: 48px 0;
      border-top: 1px solid var(--border);
      text-align: center;
    }
    footer a { color: var(--text-muted); text-decoration: none; }
    footer a:hover { color: var(--purple); }

    /* ─────────────────────── RESPONSIVE ─────────────────────── */
    @media (max-width: 768px) {
      section { padding: 60px 0; }
      .steps { grid-template-columns: 1fr; }
      .step::after { display: none; }
      .cat-grid { grid-template-columns: 1fr 1fr; }
      .price-card { padding: 32px 24px; }
    }
    @media (max-width: 480px) {
      .cat-grid { grid-template-columns: 1fr; }
      .hero-cta { flex-direction: column; }
      .proof-sep { display: none; }
    }
  </style>
</head>

<body>
  <AnalyticsBody />

  <!-- ─────────── HERO ─────────── -->
  <section id="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-eyebrow">
          <span class="badge"><span class="dot"></span>50 Professional Skills for Claude Code</span>
        </div>

        <h1 class="hero-h1">
          Your AI assistant.<br>
          <span class="grad">Actually doing your job.</span>
        </h1>

        <p class="hero-sub">
          50 production-ready Claude Code skills — built on official Anthropic best practices.
          Code review, security audits, testing, architecture, debugging.
          <strong style="color:var(--text)">Installed in 60 seconds.</strong>
        </p>

        <div class="hero-cta">
          <a href="#pricing" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            Get the Bundle — $15
          </a>
          <a href="#skills" class="btn-secondary">See all 50 skills ↓</a>
        </div>

        <!-- Terminal demo -->
        <div class="terminal">
          <div class="terminal-header">
            <span class="t-dot r"></span>
            <span class="t-dot y"></span>
            <span class="t-dot g"></span>
            <span class="terminal-title">claude — your-project/</span>
          </div>
          <div class="terminal-body">
            <div class="t-line"><span class="t-prompt">❯</span><span class="t-cmd">/code-review</span></div>
            <div class="t-line"><span class="t-out">Reviewing 3 changed files...</span></div>
            <div class="t-line"><span class="t-green">✓</span><span class="t-out">auth.ts — 1 HIGH: JWT secret in env, rotation needed</span></div>
            <div class="t-line"><span class="t-green">✓</span><span class="t-out">api.ts — 2 MEDIUM: missing input validation on line 47</span></div>
            <div class="t-line"><span class="t-purple">❯</span><span class="t-cmd">/commit-message</span></div>
            <div class="t-line"><span class="t-green">feat(auth): add JWT refresh token rotation</span></div>
            <div class="t-line"><span class="t-out">Co-authored-by: Claude &lt;noreply@anthropic.com&gt;</span></div>
          </div>
        </div>

        <!-- Proof numbers -->
        <div class="hero-proof">
          <div class="proof-item">
            <div class="proof-num">50</div>
            <div class="proof-label">Skills included</div>
          </div>
          <div class="proof-sep"></div>
          <div class="proof-item">
            <div class="proof-num">8</div>
            <div class="proof-label">Categories</div>
          </div>
          <div class="proof-sep"></div>
          <div class="proof-item">
            <div class="proof-num">60s</div>
            <div class="proof-label">To install</div>
          </div>
          <div class="proof-sep"></div>
          <div class="proof-item">
            <div class="proof-num">0</div>
            <div class="proof-label">Config required</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── MARQUEE ─────────── -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <!-- Set 1 -->
      <div class="marquee-item"><span></span>/code-review</div>
      <div class="marquee-item"><span></span>/security-audit</div>
      <div class="marquee-item"><span></span>/write-tests</div>
      <div class="marquee-item"><span></span>/debug-smart</div>
      <div class="marquee-item"><span></span>/commit-message</div>
      <div class="marquee-item"><span></span>/architecture-review</div>
      <div class="marquee-item"><span></span>/sql-injection</div>
      <div class="marquee-item"><span></span>/onboard-codebase</div>
      <div class="marquee-item"><span></span>/performance-review</div>
      <div class="marquee-item"><span></span>/pr-description</div>
      <div class="marquee-item"><span></span>/auth-review</div>
      <div class="marquee-item"><span></span>/task-breakdown</div>
      <div class="marquee-item"><span></span>/typescript-errors</div>
      <div class="marquee-item"><span></span>/database-schema</div>
      <div class="marquee-item"><span></span>/edge-cases</div>
      <!-- Set 2 (duplicate for seamless loop) -->
      <div class="marquee-item"><span></span>/code-review</div>
      <div class="marquee-item"><span></span>/security-audit</div>
      <div class="marquee-item"><span></span>/write-tests</div>
      <div class="marquee-item"><span></span>/debug-smart</div>
      <div class="marquee-item"><span></span>/commit-message</div>
      <div class="marquee-item"><span></span>/architecture-review</div>
      <div class="marquee-item"><span></span>/sql-injection</div>
      <div class="marquee-item"><span></span>/onboard-codebase</div>
      <div class="marquee-item"><span></span>/performance-review</div>
      <div class="marquee-item"><span></span>/pr-description</div>
      <div class="marquee-item"><span></span>/auth-review</div>
      <div class="marquee-item"><span></span>/task-breakdown</div>
      <div class="marquee-item"><span></span>/typescript-errors</div>
      <div class="marquee-item"><span></span>/database-schema</div>
      <div class="marquee-item"><span></span>/edge-cases</div>
    </div>
  </div>

  <!-- ─────────── SKILLS BY CATEGORY ─────────── -->
  <section id="skills">
    <div class="container">
      <p class="section-label">What's inside</p>
      <h2 class="section-title">50 skills across 8 categories</h2>
      <p class="section-sub">Each skill is a focused instruction file that changes how Claude Code behaves — built on Anthropic's official SKILL.md format.</p>

      <div class="cat-grid">
        <div class="cat-card">
          <div class="cat-icon">🔍</div>
          <div class="cat-name">Code Quality</div>
          <div class="cat-count">8 skills</div>
          <div class="cat-skills">
            <span class="skill-chip">/code-review</span>
            <span class="skill-chip">/security-review</span>
            <span class="skill-chip">/performance-review</span>
